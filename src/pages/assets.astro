---
import Footer from "../components/Footer.astro";
import Notice from "../components/Notice.astro";
import SiteHeader from "../components/SiteHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const logoDownloads = [
  {
    label: "PNG",
    href: "/assets/logos/ri-pota-coastal-signal.png",
    previewSrc: "/assets/logos/ri-pota-coastal-signal.png",
    previewAlt: "Full-color RI POTA coastal signal PNG logo preview.",
    detail: "High-quality 1254 x 1254 raster export for GitHub and social profiles.",
  },
  {
    label: "SVG",
    href: "/assets/logos/ri-pota-coastal-signal.svg",
    previewSrc: "/assets/logos/ri-pota-coastal-signal.svg",
    previewAlt: "Full-color RI POTA coastal signal SVG logo preview.",
    detail: "Full-color vector master for web pages, print layouts, and future exports.",
  },
];

const sharePreviews = [
  {
    label: "Activate All RI 2026",
    href: "/assets/activate-ri-2026-share-card.png",
    previewSrc: "/assets/activate-ri-2026-share-card.png",
    previewAlt:
      "Activate All RI 2026 hero preview with event dates, coverage totals, and the Rhode Island volunteer coverage map.",
    detail: "Social preview image used by the Activate All RI 2026 overview page.",
  },
];
---

<BaseLayout
  title="Assets"
  description="Download Rhode Island POTA community logo assets."
  canonicalPath="/assets/"
>
  <SiteHeader variant="solid" />
  <main id="main">
    <section class="section asset-hero" aria-labelledby="asset-title">
      <div class="container asset-layout">
        <div class="asset-copy">
          <p class="eyebrow">Community assets</p>
          <h1 id="asset-title">RI POTA logo files</h1>
          <p class="lead">
            Download the coastal signal mark for Rhode Island POTA community pages,
            project profiles, and local coordination materials.
          </p>
        </div>
        <div class="asset-preview" aria-label="RI POTA coastal signal logo preview">
          <img
            src="/assets/logos/ri-pota-coastal-signal.png"
            alt="RI POTA coastal signal logo with lighthouse, radio waves, Rhode Island outline, and water bands."
          />
        </div>
      </div>
    </section>

    <section class="section asset-downloads-section" aria-labelledby="downloads-title">
      <div class="container">
        <div class="section-header">
          <p class="eyebrow">Downloads</p>
          <h2 id="downloads-title">Use the format that fits</h2>
          <p class="lead">
            The SVG is the editable vector source. The PNG is the rendered
            export for services that need raster artwork.
          </p>
        </div>
        <div class="asset-downloads">
          {
            logoDownloads.map((asset) => (
              <a class="asset-download" href={asset.href} download>
                <span class="asset-download__preview">
                  <img src={asset.previewSrc} alt={asset.previewAlt} loading="lazy" />
                </span>
                <span class="asset-download__body">
                  <strong>{asset.label}</strong>
                  <span>{asset.detail}</span>
                </span>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section asset-downloads-section" aria-labelledby="share-previews-title">
      <div class="container">
        <div class="section-header">
          <p class="eyebrow">Social previews</p>
          <h2 id="share-previews-title">Open Graph cards</h2>
          <p class="lead">
            Local previews for page-specific share images. Social platforms still
            need a public URL to scrape the full share sheet.
          </p>
        </div>
        <div class="asset-downloads asset-downloads--wide">
          {
            sharePreviews.map((asset) => (
              <a class="asset-download asset-download--wide" href={asset.href}>
                <span class="asset-download__preview">
                  <img src={asset.previewSrc} alt={asset.previewAlt} loading="lazy" />
                </span>
                <span class="asset-download__body">
                  <strong>{asset.label}</strong>
                  <span>{asset.detail}</span>
                </span>
              </a>
            ))
          }
        </div>
      </div>
    </section>
    <Notice />
  </main>
  <Footer />
</BaseLayout>
