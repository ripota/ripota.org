---
import CoverageSummary from "../../components/activate-ri/CoverageSummary.astro";
import EventHero from "../../components/activate-ri/EventHero.astro";
import EventNav from "../../components/activate-ri/EventNav.astro";
import Footer from "../../components/Footer.astro";
import Notice from "../../components/Notice.astro";
import ReferenceMap from "../../components/ReferenceMap.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Activate All RI 2026"
  description="A Rhode Island POTA community weekend to cover all 61 Rhode Island references."
  canonicalPath="/activate-ri-2026/"
>
  <SiteHeader variant="solid" showEventLink />
  <main id="main">
    <EventHero />
    <section class="section event-overview" aria-labelledby="event-overview-title">
      <div class="container">
        <EventNav />
        <section class="event-guidance" aria-labelledby="how-this-works-title">
          <div class="section-header section-header--compact">
            <p class="eyebrow">Activator guide</p>
            <h2 id="how-this-works-title">How this works</h2>
            <p class="lead">
              Activate All RI 2026 is a community coordination effort. The
              public schedule helps activators avoid accidental overlap and
              helps hunters find Rhode Island references during the event.
            </p>
          </div>
          <div class="event-guidance__grid">
            <article class="event-guidance__item">
              <h3>Goal</h3>
              <p>
                Cover all 61 Rhode Island POTA references during the event
                window by sharing planned activation stops in one schedule.
              </p>
            </article>
            <article class="event-guidance__item">
              <h3>Coverage</h3>
              <p>
                A covered park has a planned activation window. It is not an
                official reservation, guarantee of operation, or guarantee of
                QSOs.
              </p>
            </article>
            <article class="event-guidance__item">
              <h3>Time blocks</h3>
              <p>
                Three-hour blocks keep the schedule easy to scan. Pick the
                closest window and update your plan if the timing changes.
              </p>
            </article>
            <article class="event-guidance__item">
              <h3>Official records</h3>
              <p>
                Use official Parks on the Air resources for rules, references,
                accounts, spots, logs, awards, and activation validity.
              </p>
            </article>
          </div>
        </section>
        <div class="section-header">
          <p class="eyebrow">Coverage plan</p>
          <h2 id="event-overview-title">One coordinated weekend</h2>
          <p class="lead">
            The schedule tracks planned activation windows and coverage gaps for
            Rhode Island references. Use the park list to find references that
            still need volunteer coverage.
          </p>
        </div>
        <CoverageSummary />
        <ReferenceMap
          id="activate-ri-coverage-map"
          variant="coverage"
          title="Map of Activate All RI 2026 coverage"
          caption="Coverage means a planned activation window for community coordination. Official Parks on the Air resources remain authoritative for rules, spots, logs, awards, and activation validity."
          phaseFocus="volunteer"
          legendPlacement="below"
          legendTitle="Volunteer coverage legend"
        />
      </div>
    </section>
    <Notice />
  </main>
  <Footer />
</BaseLayout>
