---
import EventNav from "../../components/activate-ri/EventNav.astro";
import ParkCoverageTable from "../../components/activate-ri/ParkCoverageTable.astro";
import Footer from "../../components/Footer.astro";
import Notice from "../../components/Notice.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Activate All RI 2026 Park Coverage"
  description="Coverage status for Rhode Island POTA references in Activate All RI 2026."
  canonicalPath="/activate-ri-2026/parks/"
>
  <SiteHeader variant="solid" />
  <main id="main">
    <section class="section event-page" aria-labelledby="parks-title">
      <div class="container">
        <EventNav />
        <div class="section-header">
          <p class="eyebrow">Park coverage</p>
          <h1 id="parks-title">Coverage by park</h1>
          <p class="lead">
            A reference-by-reference view of planned coverage and gaps for the
            2026 Rhode Island POTA weekend.
          </p>
        </div>
        <ParkCoverageTable />
      </div>
    </section>
    <Notice />
  </main>
  <Footer />
</BaseLayout>
