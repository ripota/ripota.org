---
import EventNav from "../../components/activate-ri/EventNav.astro";
import ScheduleTable from "../../components/activate-ri/ScheduleTable.astro";
import Footer from "../../components/Footer.astro";
import Notice from "../../components/Notice.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Activate All RI 2026 Schedule"
  description="Planned Activate All RI 2026 activation windows by date, park, and activator."
  canonicalPath="/activate-ri-2026/schedule/"
>
  <SiteHeader variant="solid" showEventLink />
  <main id="main">
    <section class="section event-page" aria-labelledby="schedule-title">
      <div class="container">
        <EventNav />
        <div class="section-header">
          <p class="eyebrow">Activation windows</p>
          <h1 id="schedule-title">Event schedule</h1>
          <p class="lead">
            Planned activation windows for Activate All RI 2026. Official POTA
            spots and logs remain the source of truth during and after each activation.
          </p>
        </div>
        <ScheduleTable />
      </div>
    </section>
    <Notice />
  </main>
  <Footer />
</BaseLayout>
