---
import EventNav from "../../components/activate-ri/EventNav.astro";
import EditLinkResendForm from "../../components/activate-ri/EditLinkResendForm.astro";
import VolunteerForm from "../../components/activate-ri/VolunteerForm.astro";
import Footer from "../../components/Footer.astro";
import Notice from "../../components/Notice.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Volunteer for Activate All RI 2026"
  description="Submit a Rhode Island POTA activation plan for organizer review."
  canonicalPath="/activate-ri-2026/volunteer/"
>
  <SiteHeader variant="solid" showEventLink />
  <main id="main">
    <section class="section event-page" aria-labelledby="volunteer-title">
      <div class="container">
        <EventNav />
        <div class="section-header">
          <p class="eyebrow">Activator signup</p>
          <h1 id="volunteer-title">Volunteer to activate</h1>
          <p class="lead">
            Share one planned activation or a multi-park plan for organizer
            review. Each stop uses a three-hour block so hunters and organizers
            can scan coverage consistently.
          </p>
        </div>
        <VolunteerForm />
        <EditLinkResendForm />
      </div>
    </section>
    <Notice />
  </main>
  <Footer />
</BaseLayout>
