---
import ReferenceMap from "./ReferenceMap.astro";
import { resourceIntro, resourceLinks } from "../data/site";

---

<div class="resource-layout">
  <div class="resource-copy">
    <div class="section-header">
      <p class="eyebrow">Rhode Island references</p>
      <h2>Current RI POTA references</h2>
    </div>
    <p class="lead">
      {resourceIntro}
    </p>
    <div class="button-row">
      {
        resourceLinks.map((link) => (
          <a class="text-link" href={link.href}>{link.label}</a>
        ))
      }
    </div>
  </div>
  <ReferenceMap
    id="ri-reference-map"
    variant="home"
    title="Map of Rhode Island POTA references"
    caption="Reference data generated from official POTA park data and reviewed public boundary sources. Verify operating details in the POTA app before activating."
  />
</div>
