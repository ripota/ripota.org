---
import ActivateRiIdentityFields from "./ActivateRiIdentityFields.astro";
import ActivateRiFrequencyNote from "./ActivateRiFrequencyNote.astro";
import ActivateRiOrganizerNotesField from "./ActivateRiOrganizerNotesField.astro";
import ActivateRiRequiredNote from "./ActivateRiRequiredNote.astro";
import ActivateRiStopsSection from "./ActivateRiStopsSection.astro";

const turnstileSiteKey =
  import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
---

<script
  is:inline
  src="https://challenges.cloudflare.com/turnstile/v0/api.js"
  async
  defer
></script>

<form class="event-form" method="post" action="/api/activate-ri-2026/plans" data-activate-ri-volunteer novalidate>
  <ActivateRiRequiredNote />
  <ActivateRiIdentityFields clubDatalistId="activate-ri-clubs" />
  <datalist id="activate-ri-clubs" data-club-options></datalist>
  <div
    class="existing-activation-notice"
    data-existing-activation-notice
    aria-live="polite"
    hidden
  >
    <p>
      <strong>We already have an activation plan for this callsign and email.</strong>
      You can also keep going here; submitting this form will merge these parks into your existing plan.
    </p>
    <div class="form-actions">
      <button class="button" data-variant="light" type="button" data-send-existing-edit-link>
        Email me my edit link
      </button>
      <span class="form-help" data-existing-activation-status></span>
    </div>
  </div>

  <ActivateRiStopsSection mode="volunteer" includeInitialStop={true} />

  <ActivateRiOrganizerNotesField />

  <ActivateRiFrequencyNote />

  <div
    class="cf-turnstile"
    data-sitekey={turnstileSiteKey}
    data-action="turnstile-spin-v1"
  />

  <button class="button" data-variant="primary" type="submit" data-submit-button>
    Submit for review
  </button>
  <output class="form-status" data-form-status aria-live="polite"></output>
</form>

<dialog class="form-confirmation" data-submit-confirmation>
  <div class="form-confirmation__body">
    <p class="eyebrow">Submission received</p>
    <h2>Plan sent for organizer review</h2>
    <p>
      Your activation plan was submitted. Check your email for the private edit
      link before closing this page.
    </p>
    <div class="form-actions">
      <a class="button" data-variant="primary" href="/activate-ri-2026/" data-confirmation-overview>
        Back to event overview
      </a>
    </div>
  </div>
</dialog>

<script>
  import {
    appendBlankStop,
    clearFieldError,
    fieldErrorElement,
    firstEmptyStopCard,
    parkReferenceAlreadySelected,
    populateClubDatalist,
    reportControlValidity,
    resetTurnstile,
    selectParkReference,
    selectedParkReference,
    selectedValues,
    setupCallsignFields,
    setupDocumentPopupDismissal,
    setupStopCards,
    setControlValidity,
    stopErrorElement,
    uppercaseFormValue,
    type ValidationControl,
  } from "../../lib/activate-ri/form-client";
  import {
    formatVolunteerMissingFieldSummary,
    formatVolunteerProblemFieldSummary,
    volunteerRequiredFieldMessage,
    type VolunteerRequiredField,
  } from "../../lib/activate-ri/volunteer-form-validation";

  const form = document.querySelector("[data-activate-ri-volunteer]") as HTMLFormElement | null;
  const status = document.querySelector("[data-form-status]") as HTMLOutputElement | null;
  const submitButton = document.querySelector("[data-submit-button]") as HTMLButtonElement | null;
  const submitConfirmation = document.querySelector("[data-submit-confirmation]") as HTMLDialogElement | null;
  const stopsContainer = document.querySelector<HTMLElement>("[data-stops-container]");
  const addStopButton = document.querySelector("[data-add-stop]");
  const existingActivationNotice = document.querySelector<HTMLElement>("[data-existing-activation-notice]");
  const existingActivationStatus = document.querySelector<HTMLElement>("[data-existing-activation-status]");
  const sendExistingEditLinkButton = document.querySelector<HTMLButtonElement>("[data-send-existing-edit-link]");
  let isSubmitting = false;
  let existingActivationCheckId = 0;
  let lastExistingActivationLookup = "";
  let isSendingExistingEditLink = false;

  setupCallsignFields();
  setupRequiredFieldValidation();
  setupExistingActivationHint();
  void populateClubDatalist("activate-ri-clubs");
  setupStopCards({ validatePark: true, setupErrorDescriptions: true });
  prefillParkFromUrl();
  setupDocumentPopupDismissal();

  addStopButton?.addEventListener("click", () => {
    const stop = appendBlankStop(stopsContainer);
    setupStopCards({ validatePark: true, setupErrorDescriptions: true });
    stop?.querySelector<HTMLInputElement>("[data-park-input]")?.focus();
  });

  document.addEventListener("activate-ri:add-park", (event) => {
    const reference = (event as CustomEvent<{ reference?: string }>).detail?.reference;
    if (!reference) {
      return;
    }

    addParkReferenceToForm(reference, { focusIdentity: true });
  });

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();

    if (isSubmitting) {
      return;
    }

    if (!validateVolunteerForm()) {
      return;
    }

    isSubmitting = true;
    if (submitButton) {
      submitButton.disabled = true;
    }

    setFormStatus("Submitting...");

    try {
      const response = await fetch(form.action, {
        method: "POST",
        body: JSON.stringify(formToPayload(new FormData(form))),
        headers: { "content-type": "application/json" },
      });
      const data = await parseResponse(response);

      if (response.ok && data.ok) {
        form.reset();
        setupStopCards({ validatePark: true, setupErrorDescriptions: true });
        setFormStatus(data.message ?? "Submission received for organizer review.", "success");
        resetTurnstile();
        showSubmitConfirmation();
      } else {
        setFormStatus(data.errors?.join(" ") ?? data.message ?? "Submission failed.", "error");
        resetTurnstile();
      }
    } catch {
      setFormStatus("Submission failed. Please try again later.", "error");
      resetTurnstile();
    } finally {
      isSubmitting = false;
      if (submitButton) {
        submitButton.disabled = false;
      }
    }
  });

  async function parseResponse(response: Response): Promise<{ ok: boolean; message?: string; errors?: string[] }> {
    const contentType = response.headers.get("content-type") ?? "";

    if (!contentType.includes("application/json")) {
      return { ok: false };
    }

    return response.json();
  }

  function setupExistingActivationHint(): void {
    const callsignField = form?.elements.namedItem("submitterCallsign") as HTMLInputElement | null;
    const emailField = form?.elements.namedItem("submitterEmail") as HTMLInputElement | null;

    callsignField?.addEventListener("blur", () => {
      void checkExistingActivation();
    });
    emailField?.addEventListener("blur", () => {
      void checkExistingActivation();
    });
    callsignField?.addEventListener("input", () => clearExistingActivationHint());
    emailField?.addEventListener("input", () => clearExistingActivationHint());
    sendExistingEditLinkButton?.addEventListener("click", () => {
      void sendExistingEditLink();
    });
  }

  async function checkExistingActivation(): Promise<void> {
    const identity = currentActivatorIdentity();
    if (!identity || identity.emailField.validity.valid === false) {
      clearExistingActivationHint();
      return;
    }

    const lookupKey = `${identity.callsign}\n${identity.email}`;
    if (lookupKey === lastExistingActivationLookup && !existingActivationNotice?.hidden) {
      return;
    }

    const checkId = ++existingActivationCheckId;
    lastExistingActivationLookup = lookupKey;

    try {
      const response = await fetch("/api/activate-ri-2026/activation-lookup", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({
          callsign: identity.callsign,
          email: identity.email,
        }),
      });
      const data = await parseResponse(response) as { ok: boolean; exists?: boolean };

      if (checkId !== existingActivationCheckId) {
        return;
      }

      if (response.ok && data.ok && data.exists) {
        showExistingActivationHint();
      } else {
        clearExistingActivationHint({ keepLookup: true });
      }
    } catch {
      clearExistingActivationHint({ keepLookup: true });
    }
  }

  async function sendExistingEditLink(): Promise<void> {
    const identity = currentActivatorIdentity();
    if (!identity || isSendingExistingEditLink) {
      return;
    }

    isSendingExistingEditLink = true;
    if (sendExistingEditLinkButton) {
      sendExistingEditLinkButton.disabled = true;
    }
    existingActivationStatus?.replaceChildren("Sending...");

    try {
      const response = await fetch("/api/activate-ri-2026/resend-edit-link", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({
          callsign: identity.callsign,
          email: identity.email,
        }),
      });
      const data = await parseResponse(response);

      if (!response.ok || !data.ok) {
        existingActivationStatus?.replaceChildren(data.errors?.join(" ") ?? "Unable to send the edit link.");
        return;
      }

      existingActivationStatus?.replaceChildren(data.message ?? "If we found a matching signup, we sent the private edit link.");
    } catch {
      existingActivationStatus?.replaceChildren("Unable to send the edit link. Please try again later.");
    } finally {
      isSendingExistingEditLink = false;
      if (sendExistingEditLinkButton) {
        sendExistingEditLinkButton.disabled = false;
      }
    }
  }

  function currentActivatorIdentity(): {
    callsign: string;
    email: string;
    emailField: HTMLInputElement;
  } | null {
    const callsignField = form?.elements.namedItem("submitterCallsign") as HTMLInputElement | null;
    const emailField = form?.elements.namedItem("submitterEmail") as HTMLInputElement | null;
    const callsign = callsignField?.value.trim().toUpperCase() ?? "";
    const email = emailField?.value.trim().toLowerCase() ?? "";

    if (!callsign || !email || !emailField) {
      return null;
    }

    return { callsign, email, emailField };
  }

  function showExistingActivationHint(): void {
    if (existingActivationNotice) {
      existingActivationNotice.hidden = false;
    }
    existingActivationStatus?.replaceChildren();
  }

  function clearExistingActivationHint(options: { keepLookup?: boolean } = {}): void {
    existingActivationCheckId += 1;
    if (!options.keepLookup) {
      lastExistingActivationLookup = "";
    }
    if (existingActivationNotice) {
      existingActivationNotice.hidden = true;
    }
    existingActivationStatus?.replaceChildren();
  }

  function formToPayload(data: FormData) {
    return {
      submitterCallsign: uppercaseFormValue(data.get("submitterCallsign")),
      submitterName: data.get("submitterName"),
      submitterEmail: data.get("submitterEmail"),
      club: data.get("club"),
      organizerNotes: data.get("organizerNotes"),
      turnstileToken: data.get("cf-turnstile-response"),
      stops: Array.from(document.querySelectorAll<HTMLElement>("[data-stop-card]")).map((stop) => ({
        parkReference: stop.querySelector<HTMLInputElement>("[data-park-reference]")?.value,
        plannedDate: (stop.querySelector("[data-planned-date]") as HTMLSelectElement | null)?.value,
        timeBlock: (stop.querySelector("[data-time-block]") as HTMLSelectElement | null)?.value,
        bands: selectedValues(stop.querySelector<HTMLElement>("[data-bands]")),
        modes: selectedValues(stop.querySelector<HTMLElement>("[data-modes]")),
        publicNotes: stop.querySelector<HTMLTextAreaElement>("[data-public-notes]")?.value ?? "",
      })),
    };
  }

  function setupRequiredFieldValidation(): void {
    ["submitterCallsign", "submitterName", "submitterEmail"].forEach((name) => {
      const field = form?.elements.namedItem(name) as HTMLInputElement | null;
      const errorElement = fieldErrorElement(field);

      field?.addEventListener("input", () => {
        if (field.value.trim()) {
          clearFieldError(field, errorElement);
        }
      });
    });
  }

  function prefillParkFromUrl(): void {
    const reference = new URLSearchParams(window.location.search).get("park");
    if (!reference) {
      return;
    }

    addParkReferenceToForm(reference.toUpperCase(), { silentInvalid: true, focusIdentity: true });
  }

  function addParkReferenceToForm(reference: string, options: { focusIdentity?: boolean; silentInvalid?: boolean } = {}): void {
    const normalizedReference = reference.trim().toUpperCase();

    if (parkReferenceAlreadySelected(normalizedReference)) {
      if (options.focusIdentity) {
        focusVolunteerIdentityFields();
      }
      setFormStatus(`${normalizedReference} is already in the activation plan.`);
      return;
    }

    const targetStop = firstEmptyStopCard() ?? appendBlankStop(stopsContainer);
    if (!targetStop) {
      return;
    }

    const selected = selectParkReference(targetStop, normalizedReference);
    if (!selected) {
      if (!options.silentInvalid) {
        setFormStatus(`Could not find ${normalizedReference} in the park list.`, "error");
      }
      return;
    }

    setupStopCards({ validatePark: true, setupErrorDescriptions: true });
    if (options.focusIdentity) {
      focusVolunteerIdentityFields();
    }
    setFormStatus(`${normalizedReference} added to the activation plan. Choose the date, time, bands, and modes before submitting.`);
  }

  function focusVolunteerIdentityFields(): void {
    form?.scrollIntoView({ behavior: "smooth", block: "start" });
    (form?.elements.namedItem("submitterCallsign") as HTMLInputElement | null)?.focus({
      preventScroll: true,
    });
  }

  function validateVolunteerForm(): boolean {
    const invalidFields: VolunteerRequiredField[] = [];
    const problemFields: VolunteerRequiredField[] = [];
    const invalidControls: ValidationControl[] = [];

    const recordField = (
      field: VolunteerRequiredField,
      control: ValidationControl | null,
      errorElement: HTMLElement | null,
      message = volunteerRequiredFieldMessage(field),
      problem = false,
    ) => {
      if (!control) {
        return;
      }

      control.setAttribute("aria-invalid", "true");
      setControlValidity(control, message);
      errorElement?.replaceChildren(message);
      invalidFields.push(field);
      if (problem) {
        problemFields.push(field);
      }
      invalidControls.push(control);
    };

    const validateNamedRequiredField = (field: Extract<VolunteerRequiredField, "submitterCallsign" | "submitterName" | "submitterEmail">) => {
      const control = form?.elements.namedItem(field) as HTMLInputElement | null;
      const errorElement = fieldErrorElement(control);

      if (!control) {
        return;
      }

      clearFieldError(control, errorElement);

      if (!control.value.trim()) {
        recordField(field, control, errorElement);
      } else if (field === "submitterEmail" && !control.validity.valid) {
        recordField(field, control, errorElement, "Enter a valid email address.", true);
      }
    };

    validateNamedRequiredField("submitterCallsign");
    validateNamedRequiredField("submitterName");
    validateNamedRequiredField("submitterEmail");

    const stops = Array.from(document.querySelectorAll<HTMLElement>("[data-stop-card]"));

    stops.forEach((stop, index) => {
      const parkInput = stop.querySelector<HTMLInputElement>("[data-park-input]");
      const parkReference = stop.querySelector<HTMLInputElement>("[data-park-reference]");
      const parkCombobox = stop.querySelector<HTMLElement>("[data-park-combobox]");
      const plannedDate = stop.querySelector("[data-planned-date]") as HTMLSelectElement | null;
      const timeBlock = stop.querySelector("[data-time-block]") as HTMLSelectElement | null;

      if (parkInput && parkReference && parkCombobox) {
        clearFieldError(parkInput, stopErrorElement(stop, "park"));
        parkReference.value = selectedParkReference(parkInput.value.trim(), parkCombobox);

        if (!parkReference.value) {
          recordField(`stop.${index}.park`, parkInput, stopErrorElement(stop, "park"));
        }
      }

      if (plannedDate) {
        clearFieldError(plannedDate, stopErrorElement(stop, "plannedDate"));
        if (!plannedDate.value) {
          recordField(`stop.${index}.plannedDate`, plannedDate, stopErrorElement(stop, "plannedDate"));
        }
      }

      if (timeBlock) {
        clearFieldError(timeBlock, stopErrorElement(stop, "timeBlock"));
        if (!timeBlock.value) {
          recordField(`stop.${index}.timeBlock`, timeBlock, stopErrorElement(stop, "timeBlock"));
        }
      }

      stop.querySelectorAll<HTMLElement>("[data-multi-select]").forEach((multiSelect) => {
        const toggle = multiSelect.querySelector<HTMLButtonElement>("[data-multi-toggle]");
        const hasSelection = selectedValues(multiSelect).length > 0;
        const field = multiSelect.hasAttribute("data-bands")
          ? `stop.${index}.bands`
          : `stop.${index}.modes`;

        clearFieldError(toggle, stopErrorElement(stop, multiSelect.hasAttribute("data-bands") ? "bands" : "modes"));

        if (!hasSelection) {
          recordField(
            field as VolunteerRequiredField,
            toggle,
            stopErrorElement(stop, multiSelect.hasAttribute("data-bands") ? "bands" : "modes"),
          );
        }
      });
    });

    if (invalidFields.length === 0) {
      setFormStatus("");
      return true;
    }

    const summary = problemFields.length > 0
      ? formatVolunteerProblemFieldSummary(invalidFields)
      : formatVolunteerMissingFieldSummary(invalidFields);
    setFormStatus(summary, "error");
    const firstInvalidControl = invalidControls[0] ?? null;
    firstInvalidControl?.focus();
    reportControlValidity(firstInvalidControl);
    return false;
  }

  function setFormStatus(message: string, kind?: "error" | "success"): void {
    status?.replaceChildren(message);

    if (!status) {
      return;
    }

    if (kind) {
      status.dataset.status = kind;
    } else {
      delete status.dataset.status;
    }
  }

  function showSubmitConfirmation(): void {
    if (submitConfirmation?.showModal) {
      submitConfirmation.showModal();
      submitConfirmation.querySelector<HTMLAnchorElement>("[data-confirmation-overview]")?.focus();
    }
  }

</script>
