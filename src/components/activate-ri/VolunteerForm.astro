---
import references from "../../data/ri-references.json";
import { activateRiTimeBlocks } from "../../lib/activate-ri/time-blocks";
import {
  activateRiBandOptions,
  activateRiModeOptions,
} from "../../lib/activate-ri/validation";

const turnstileSiteKey =
  import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;

function parkOptionLabel(reference: (typeof references)[number]): string {
  const counties = reference.counties?.join(", ");
  const countyLabel = counties ? ` (${counties})` : "";

  return `${reference.reference} - ${reference.name}${countyLabel}`;
}

function parkOptionSearch(reference: (typeof references)[number]): string {
  return [
    reference.reference,
    reference.name,
    ...(reference.counties ?? []),
  ].join(" ").toLowerCase();
}
---

<script
  is:inline
  src="https://challenges.cloudflare.com/turnstile/v0/api.js"
  async
  defer
></script>

<form class="event-form" method="post" action="/api/activate-ri-2026/plans" data-activate-ri-volunteer>
  <div class="form-grid form-grid--identity">
    <label>
      Callsign
      <input
        class="callsign-input"
        id="activate-ri-callsign"
        name="submitterCallsign"
        autocomplete="nickname"
        autocapitalize="characters"
        aria-describedby="activate-ri-callsign-help"
        spellcheck="false"
        required
      />
      <span id="activate-ri-callsign-help" class="form-help">
        Use the callsign that should appear on the public schedule.
      </span>
    </label>
    <label>
      Name
      <input name="submitterName" autocomplete="name" required />
    </label>
    <label>
      Email
      <input
        id="activate-ri-email"
        name="submitterEmail"
        type="email"
        autocomplete="email"
        aria-describedby="activate-ri-email-help"
        required
      />
      <span id="activate-ri-email-help" class="form-help">
        Used for your private edit link. It is not shown publicly.
      </span>
    </label>
    <label>
      Club / group affiliation
      <input name="club" list="activate-ri-clubs" autocomplete="organization" />
    </label>
  </div>
  <datalist id="activate-ri-clubs" data-club-options></datalist>

  <div class="activation-stops" data-stops>
    <fieldset class="activation-stop-fieldset activation-stop-card" data-stop-card>
      <div class="activation-stop-card__header">
        <legend class="activation-stop-card__title" data-stop-title>Activation stop 1</legend>
        <button class="button activation-stop-card__remove" type="button" data-remove-stop hidden>
          Remove
        </button>
      </div>
      <div class="form-grid">
        <div class="form-field form-field--wide">
          <span class="field-label-row">
            <span class="form-label">Park</span>
            <span class="help-popover">
              <button
                class="help-popover__button"
                type="button"
                aria-label="Help for park field"
              >?</button>
              <span class="help-popover__bubble" role="tooltip">
                Choose from the suggestion list so the correct POTA reference
                is saved with the stop.
              </span>
            </span>
          </span>
          <span class="park-combobox" data-park-combobox>
            <input
              data-park-input
              aria-label="Park"
              placeholder="Type a reference, park, or county"
              autocomplete="off"
              role="combobox"
              aria-autocomplete="list"
              aria-expanded="false"
              required
            />
            <input data-park-reference type="hidden" />
            <span class="park-combobox__popup" data-park-results hidden>
              <span class="park-combobox__scroller">
                <table class="park-combobox__table">
                  <thead>
                    <tr>
                      <th scope="col">Ref</th>
                      <th scope="col">Park</th>
                      <th scope="col">County</th>
                    </tr>
                  </thead>
                  <tbody>
                    {
                      references.map((reference) => (
                        <tr
                          data-park-option
                          data-reference={reference.reference}
                          data-label={parkOptionLabel(reference)}
                          data-search={parkOptionSearch(reference)}
                        >
                          <td>
                            <button type="button" data-park-select>{reference.reference}</button>
                          </td>
                          <td>{reference.name}</td>
                          <td>{reference.counties?.join(", ") ?? "Unknown county"}</td>
                        </tr>
                      ))
                    }
                  </tbody>
                </table>
              </span>
              <span class="park-combobox__empty" data-park-empty hidden>No matching parks.</span>
            </span>
          </span>
          <span class="form-help">
            Select a park from the suggestions before submitting.
          </span>
        </div>
        <label>
          Date
          <select data-planned-date required>
            <option value="2026-09-10">Thursday, September 10 soft start</option>
            <option value="2026-09-11">Friday, September 11</option>
            <option value="2026-09-12">Saturday, September 12</option>
            <option value="2026-09-13">Sunday, September 13</option>
          </select>
        </label>
        <div class="form-field">
          <span class="field-label-row">
            <span class="form-label">Time block</span>
            <span class="help-popover">
              <button
                class="help-popover__button"
                type="button"
                aria-label="Help for time block field"
              >?</button>
              <span class="help-popover__bubble" role="tooltip">
                The block is for schedule scanning. It does not mean you must
                operate for exactly three hours.
              </span>
            </span>
          </span>
          <select data-time-block required>
            <option value="">Choose a 3-hour block</option>
            {
              activateRiTimeBlocks.map((block) => (
                <option value={block.value}>{block.value} ET</option>
              ))
            }
          </select>
          <span class="form-help">
            Pick the closest planned operating window. Update it later if plans
            change.
          </span>
        </div>
        <div class="form-field">
          <span class="field-label-row">
            <span class="form-label">Bands</span>
            <span class="help-popover">
              <button
                class="help-popover__button"
                type="button"
                aria-label="Help for bands field"
              >?</button>
              <span class="help-popover__bubble" role="tooltip">
                Choose the bands you expect to try. This helps hunters plan,
                but it is not a binding promise.
              </span>
            </span>
          </span>
          <span class="multi-select" data-multi-select data-bands>
            <button
              class="multi-select__button"
              type="button"
              data-multi-toggle
              aria-expanded="false"
            >
              Choose bands
            </button>
            <span class="multi-select__menu" data-multi-menu hidden>
              {
                activateRiBandOptions.map((band) => (
                  <label class="multi-select__option">
                    <input type="checkbox" value={band} data-multi-option />
                    <span>{band}</span>
                  </label>
                ))
              }
            </span>
          </span>
          <span class="form-help">
            Select every band you expect to use.
          </span>
        </div>
        <div class="form-field">
          <span class="field-label-row">
            <span class="form-label">Modes</span>
            <span class="help-popover">
              <button
                class="help-popover__button"
                type="button"
                aria-label="Help for modes field"
              >?</button>
              <span class="help-popover__bubble" role="tooltip">
                Choose the modes you expect to try. Digital includes FT8, FT4,
                RTTY, JS8, and similar modes.
              </span>
            </span>
          </span>
          <span class="multi-select" data-multi-select data-modes>
            <button
              class="multi-select__button"
              type="button"
              data-multi-toggle
              aria-expanded="false"
            >
              Choose modes
            </button>
            <span class="multi-select__menu" data-multi-menu hidden>
              {
                activateRiModeOptions.map((mode) => (
                  <label class="multi-select__option">
                    <input type="checkbox" value={mode} data-multi-option />
                    <span>{mode}</span>
                  </label>
                ))
              }
            </span>
          </span>
          <span class="form-help">
            Digital covers FT8, FT4, RTTY, JS8, and similar modes.
          </span>
        </div>
      </div>
      <div class="form-field">
        <span class="field-label-row">
          <span class="form-label">Public notes for hunters</span>
          <span class="help-popover">
            <button
              class="help-popover__button"
              type="button"
              aria-label="Help for public notes field"
            >?</button>
            <span class="help-popover__bubble" role="tooltip">
              These notes are shown publicly. Avoid private contact details.
            </span>
          </span>
        </span>
        <textarea data-public-notes rows="3"></textarea>
        <span class="form-help">
          Helpful public notes include access, parking, QRP, or rove sequence
          details.
        </span>
      </div>
    </fieldset>
  </div>

  <div class="form-actions">
    <button class="button" data-variant="light" type="button" data-add-stop>
      Add another park
    </button>
  </div>

  <div class="form-field">
    <span class="field-label-row">
      <span class="form-label">Notes for organizers</span>
      <span class="help-popover">
        <button
          class="help-popover__button"
          type="button"
          aria-label="Help for organizer notes field"
        >?</button>
        <span class="help-popover__bubble" role="tooltip">
          These notes are for coordinators and are not shown on the public
          schedule.
        </span>
      </span>
    </span>
    <textarea
      name="organizerNotes"
      rows="3"
      aria-describedby="activate-ri-organizer-notes-help"
    ></textarea>
    <span id="activate-ri-organizer-notes-help" class="form-help">
      Use this for coordinator context, special constraints, or review notes.
    </span>
  </div>

  <p class="form-help">
    Frequencies are not collected here. Please use normal POTA spotting when
    your activation begins.
  </p>

  <div
    class="cf-turnstile"
    data-sitekey={turnstileSiteKey}
    data-action="turnstile-spin-v1"
  />

  <button class="button" data-variant="primary" type="submit" data-submit-button>
    Submit for review
  </button>
  <output class="form-status" data-form-status aria-live="polite"></output>
</form>

<script>
  const form = document.querySelector("[data-activate-ri-volunteer]") as HTMLFormElement | null;
  const status = document.querySelector("[data-form-status]");
  const submitButton = document.querySelector("[data-submit-button]") as HTMLButtonElement | null;
  const stopsContainer = document.querySelector("[data-stops]");
  const addStopButton = document.querySelector("[data-add-stop]");
  let isSubmitting = false;

  setupCallsignFields();
  void populateClubDatalist("activate-ri-clubs");
  setupStopCards();

  document.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof Node)) {
      return;
    }

    document.querySelectorAll<HTMLElement>("[data-park-combobox]").forEach((combo) => {
      if (!combo.contains(target)) {
        setParkPopupOpen(combo, false);
      }
    });

    document.querySelectorAll<HTMLElement>("[data-multi-select]").forEach((multiSelect) => {
      if (!multiSelect.contains(target)) {
        setMultiSelectOpen(multiSelect, false);
      }
    });
  });

  addStopButton?.addEventListener("click", () => {
    appendBlankStop()?.querySelector<HTMLInputElement>("[data-park-input]")?.focus();
  });

  document.addEventListener("activate-ri:add-park", (event) => {
    const reference = (event as CustomEvent<{ reference?: string }>).detail?.reference;
    if (!reference) {
      return;
    }

    addParkReferenceToForm(reference);
  });

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();

    if (isSubmitting) {
      return;
    }

    if (!validateStopCards()) {
      status?.replaceChildren("Choose each park from the park suggestions before submitting.");
      return;
    }

    isSubmitting = true;
    if (submitButton) {
      submitButton.disabled = true;
    }

    status?.replaceChildren("Submitting...");

    try {
      const response = await fetch(form.action, {
        method: "POST",
        body: JSON.stringify(formToPayload(new FormData(form))),
        headers: { "content-type": "application/json" },
      });
      const data = await parseResponse(response);

      if (response.ok && data.ok) {
        form.reset();
        status?.replaceChildren(data.message ?? "Submission received for organizer review.");
        resetTurnstile();
      } else {
        status?.replaceChildren(data.errors?.join(" ") ?? data.message ?? "Submission failed.");
        resetTurnstile();
      }
    } catch {
      status?.replaceChildren("Submission failed. Please try again later.");
      resetTurnstile();
    } finally {
      isSubmitting = false;
      if (submitButton) {
        submitButton.disabled = false;
      }
    }
  });

  async function parseResponse(response: Response): Promise<{ ok: boolean; message?: string; errors?: string[] }> {
    const contentType = response.headers.get("content-type") ?? "";

    if (!contentType.includes("application/json")) {
      return { ok: false };
    }

    return response.json();
  }

  function formToPayload(data: FormData) {
    return {
      submitterCallsign: uppercaseFormValue(data.get("submitterCallsign")),
      submitterName: data.get("submitterName"),
      submitterEmail: data.get("submitterEmail"),
      club: data.get("club"),
      organizerNotes: data.get("organizerNotes"),
      turnstileToken: data.get("cf-turnstile-response"),
      stops: Array.from(document.querySelectorAll<HTMLElement>("[data-stop-card]")).map((stop) => ({
        parkReference: stop.querySelector<HTMLInputElement>("[data-park-reference]")?.value,
        plannedDate: (stop.querySelector("[data-planned-date]") as HTMLSelectElement | null)?.value,
        timeBlock: (stop.querySelector("[data-time-block]") as HTMLSelectElement | null)?.value,
        bands: selectedValues(stop.querySelector<HTMLElement>("[data-bands]")),
        modes: selectedValues(stop.querySelector<HTMLElement>("[data-modes]")),
        publicNotes: stop.querySelector<HTMLTextAreaElement>("[data-public-notes]")?.value ?? "",
      })),
    };
  }

  function uppercaseFormValue(value: FormDataEntryValue | null): FormDataEntryValue | null {
    return typeof value === "string" ? value.toUpperCase() : value;
  }

  function setupCallsignFields(): void {
    document.querySelectorAll<HTMLInputElement>(".callsign-input").forEach((field) => {
      const uppercaseValue = () => {
        field.value = field.value.toUpperCase();
      };

      field.addEventListener("input", uppercaseValue);
      field.addEventListener("change", uppercaseValue);
      uppercaseValue();
    });
  }

  async function populateClubDatalist(id: string): Promise<void> {
    const datalist = document.getElementById(id);
    if (!datalist) {
      return;
    }

    try {
      const response = await fetch("/api/activate-ri-2026/public/clubs", {
        headers: { accept: "application/json" },
      });
      const body = await response.json() as { clubs?: unknown };
      const clubs = Array.isArray(body.clubs)
        ? body.clubs.filter((club): club is string => typeof club === "string")
        : [];

      datalist.replaceChildren(
        ...clubs.map((club) => {
          const option = document.createElement("option");
          option.value = club;
          return option;
        }),
      );
    } catch {
      datalist.replaceChildren();
    }
  }

  function selectedValues(root: HTMLElement | null): string[] {
    return Array.from(root?.querySelectorAll<HTMLInputElement>("[data-multi-option]:checked") ?? [])
      .map((option) => option.value);
  }

  function resetTurnstile(): void {
    const turnstile = (
      globalThis as {
        turnstile?: {
          reset?: () => void;
        };
      }
    ).turnstile;

    turnstile?.reset?.();
  }

  function setupStopCards(): void {
    const stops = Array.from(document.querySelectorAll<HTMLElement>("[data-stop-card]"));

    stops.forEach((stop, index) => {
      const title = stop.querySelector("[data-stop-title]");
      const removeButton = stop.querySelector<HTMLButtonElement>("[data-remove-stop]");
      const parkInput = stop.querySelector<HTMLInputElement>("[data-park-input]");
      const parkReference = stop.querySelector<HTMLInputElement>("[data-park-reference]");
      const parkCombobox = stop.querySelector<HTMLElement>("[data-park-combobox]");

      title?.replaceChildren(`Activation stop ${index + 1}`);

      if (removeButton) {
        removeButton.hidden = stops.length === 1;
        removeButton.onclick = () => {
          stop.remove();
          setupStopCards();
        };
      }

      if (parkInput && parkReference && parkCombobox) {
        const syncParkReference = () => {
          parkReference.value = selectedParkReference(parkInput.value.trim(), parkCombobox);
          parkInput.setCustomValidity(
            parkReference.value ? "" : "Choose a park from the suggestions.",
          );
          filterParkOptions(parkCombobox, parkInput.value);
        };

        parkInput.onfocus = () => {
          filterParkOptions(parkCombobox, parkInput.value);
          setParkPopupOpen(parkCombobox, true);
        };
        parkInput.oninput = syncParkReference;
        parkInput.onchange = syncParkReference;
        syncParkReference();

        parkCombobox.querySelectorAll<HTMLElement>("[data-park-option]").forEach((option) => {
          option.onclick = () => {
            const label = option.dataset.label ?? "";
            parkInput.value = label;
            parkReference.value = option.dataset.reference ?? "";
            parkInput.setCustomValidity("");
            setParkPopupOpen(parkCombobox, false);
          };
        });
      }

      stop.querySelectorAll<HTMLElement>("[data-multi-select]").forEach((multiSelect) => {
        const toggle = multiSelect.querySelector<HTMLButtonElement>("[data-multi-toggle]");
        if (toggle) {
          toggle.onclick = () => {
          setMultiSelectOpen(multiSelect, toggle.getAttribute("aria-expanded") !== "true");
          };
        }

        multiSelect.querySelectorAll<HTMLInputElement>("[data-multi-option]").forEach((option) => {
          option.onchange = () => {
            updateMultiSelectLabel(multiSelect);
            toggle?.setCustomValidity(selectedValues(multiSelect).length > 0 ? "" : "Choose at least one option.");
          };
        });
        updateMultiSelectLabel(multiSelect);
      });
    });
  }

  function appendBlankStop(): HTMLElement | null {
    const firstStop = document.querySelector<HTMLElement>("[data-stop-card]");
    if (!firstStop || !stopsContainer) {
      return null;
    }

    const nextStop = firstStop.cloneNode(true) as HTMLElement;
    clearStopCard(nextStop);
    stopsContainer.appendChild(nextStop);
    setupStopCards();
    return nextStop;
  }

  function addParkReferenceToForm(reference: string): void {
    const targetStop = firstEmptyStopCard() ?? appendBlankStop();
    if (!targetStop) {
      return;
    }

    const selected = selectParkReference(targetStop, reference);
    if (!selected) {
      status?.replaceChildren(`Could not find ${reference} in the park list.`);
      return;
    }

    setupStopCards();
    targetStop.scrollIntoView({ behavior: "smooth", block: "center" });
    (targetStop.querySelector("[data-planned-date]") as HTMLSelectElement | null)?.focus();
    status?.replaceChildren(`${reference} added to the activation plan. Choose the date, time, bands, and modes before submitting.`);
  }

  function firstEmptyStopCard(): HTMLElement | null {
    return Array.from(document.querySelectorAll<HTMLElement>("[data-stop-card]"))
      .find((stop) => !stop.querySelector<HTMLInputElement>("[data-park-reference]")?.value) ?? null;
  }

  function selectParkReference(stop: HTMLElement, reference: string): boolean {
    const parkInput = stop.querySelector<HTMLInputElement>("[data-park-input]");
    const parkReference = stop.querySelector<HTMLInputElement>("[data-park-reference]");
    const option = Array.from(stop.querySelectorAll<HTMLElement>("[data-park-option]"))
      .find((candidate) => candidate.dataset.reference === reference);

    if (!parkInput || !parkReference || !option) {
      return false;
    }

    parkInput.value = option.dataset.label ?? reference;
    parkReference.value = reference;
    parkInput.setCustomValidity("");
    return true;
  }

  function validateStopCards(): boolean {
    let isValid = true;
    const stops = Array.from(document.querySelectorAll<HTMLElement>("[data-stop-card]"));

    for (const stop of stops) {
      const parkInput = stop.querySelector<HTMLInputElement>("[data-park-input]");
      const parkReference = stop.querySelector<HTMLInputElement>("[data-park-reference]");
      const parkCombobox = stop.querySelector<HTMLElement>("[data-park-combobox]");

      if (!parkInput || !parkReference || !parkCombobox) {
        continue;
      }

      parkReference.value = selectedParkReference(parkInput.value.trim(), parkCombobox);
      parkInput.setCustomValidity(
        parkReference.value ? "" : "Choose a park from the suggestions.",
      );

      if (!parkReference.value) {
        parkInput.reportValidity();
        isValid = false;
      }

      stop.querySelectorAll<HTMLElement>("[data-multi-select]").forEach((multiSelect) => {
        const toggle = multiSelect.querySelector<HTMLButtonElement>("[data-multi-toggle]");
        const hasSelection = selectedValues(multiSelect).length > 0;
        toggle?.setCustomValidity(hasSelection ? "" : "Choose at least one option.");

        if (!hasSelection) {
          toggle?.reportValidity();
          isValid = false;
        }
      });
    }

    return isValid;
  }

  function clearStopCard(stop: HTMLElement): void {
    stop.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>("input:not([type='checkbox']), textarea").forEach((field) => {
      field.value = "";
    });
    stop.querySelectorAll<HTMLInputElement>("input[type='checkbox']").forEach((field) => {
      field.checked = false;
    });
    (Array.from(stop.querySelectorAll("select")) as HTMLSelectElement[]).forEach((field) => {
      field.selectedIndex = 0;
    });
    stop.querySelectorAll<HTMLElement>("[data-park-results], [data-multi-menu]").forEach((popup) => {
      popup.hidden = true;
    });
    stop.querySelectorAll<HTMLElement>("[data-multi-select]").forEach(updateMultiSelectLabel);
  }

  function selectedParkReference(value: string, combobox: HTMLElement): string {
    const normalizedValue = value.toLowerCase();
    const selectedOption = Array.from(combobox.querySelectorAll<HTMLElement>("[data-park-option]"))
      .find((option) => (
        option.dataset.reference?.toLowerCase() === normalizedValue ||
        option.dataset.label?.toLowerCase() === normalizedValue
      ));

    return selectedOption?.dataset.reference ?? "";
  }

  function filterParkOptions(combobox: HTMLElement, value: string): void {
    const terms = value.toLowerCase().split(/\s+/).filter(Boolean);
    let visibleCount = 0;

    combobox.querySelectorAll<HTMLElement>("[data-park-option]").forEach((option) => {
      const search = option.dataset.search ?? "";
      const isVisible = terms.every((term) => search.includes(term));
      option.hidden = !isVisible;
      if (isVisible) {
        visibleCount += 1;
      }
    });

    const empty = combobox.querySelector<HTMLElement>("[data-park-empty]");
    if (empty) {
      empty.hidden = visibleCount > 0;
    }
  }

  function setParkPopupOpen(combobox: HTMLElement, isOpen: boolean): void {
    combobox.querySelector<HTMLElement>("[data-park-results]")?.toggleAttribute("hidden", !isOpen);
    combobox.querySelector<HTMLInputElement>("[data-park-input]")?.setAttribute("aria-expanded", String(isOpen));
  }

  function setMultiSelectOpen(multiSelect: HTMLElement, isOpen: boolean): void {
    multiSelect.querySelector<HTMLElement>("[data-multi-menu]")?.toggleAttribute("hidden", !isOpen);
    multiSelect.querySelector<HTMLButtonElement>("[data-multi-toggle]")?.setAttribute("aria-expanded", String(isOpen));
  }

  function updateMultiSelectLabel(multiSelect: HTMLElement): void {
    const toggle = multiSelect.querySelector<HTMLButtonElement>("[data-multi-toggle]");
    const values = selectedValues(multiSelect);

    if (!toggle) {
      return;
    }

    toggle.textContent = values.length > 0 ? values.join(", ") : multiSelect.hasAttribute("data-bands") ? "Choose bands" : "Choose modes";
  }
</script>
