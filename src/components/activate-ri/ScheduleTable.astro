---
import parks from "../../../public/data/activate-ri-2026/parks.json";
import {
  timelineOptions,
  uniqueSortedValues,
} from "../../lib/activate-ri/listing";
import { timeZoneOptionForValue } from "../../lib/activate-ri/time";
import type { PublicParkSummary } from "../../lib/activate-ri/types";

const publicParks = parks as PublicParkSummary[];
const countyOptions = uniqueSortedValues(
  publicParks.map((park) => (park.counties?.length ? park.counties : ["Unknown county"])),
);
const scheduleTimeZoneOptions = ["utc", "eastern", "central", "mountain", "pacific"].map((value) =>
  timeZoneOptionForValue(value),
);
---

<form class="event-filters" data-event-filters aria-label="Schedule filters">
  <fieldset class="event-filter event-filter--timezone">
    <legend>Timezone</legend>
    <div class="timezone-segments" role="radiogroup" aria-label="Schedule timezone">
      {
        scheduleTimeZoneOptions.map((option) => (
          <label class="timezone-segment">
            <input
              type="radio"
              name="schedule-timezone"
              value={option.value}
              checked={option.value === "eastern"}
              data-timezone
            />
            <span>{option.label}</span>
          </label>
        ))
      }
    </div>
  </fieldset>
  <label class="event-filter">
    Mode
    <select class="event-filter__control" data-filter="mode">
      <option value="all">Any mode</option>
    </select>
  </label>
  <label class="event-filter">
    Band
    <select class="event-filter__control" data-filter="band">
      <option value="all">Any band</option>
    </select>
  </label>
  <label class="event-filter">
    Timeline
    <select class="event-filter__control" data-filter="timeline">
      {timelineOptions.map((option) => <option value={option.value}>{option.label}</option>)}
    </select>
  </label>
  <label class="event-filter">
    County
    <select class="event-filter__control" data-filter="county">
      <option value="all">Any county</option>
      {countyOptions.map((county) => <option value={county}>{county}</option>)}
    </select>
  </label>
</form>

<div class="event-table-wrap">
  <table class="event-table" data-filtered-table data-live-schedule data-parks={JSON.stringify(publicParks)}>
    <thead>
      <tr>
        <th scope="col">Date</th>
        <th scope="col">Time</th>
        <th scope="col">Park</th>
        <th scope="col">Activator</th>
        <th scope="col">Bands</th>
        <th scope="col">Modes</th>
        <th scope="col">Status</th>
      </tr>
    </thead>
    <tbody>
      <tr data-live-loading>
        <td colspan="7" data-label="Schedule">Loading approved activation windows...</td>
      </tr>
      <tr data-filter-empty hidden>
        <td colspan="7" data-label="Schedule">No scheduled activation windows match these filters.</td>
      </tr>
    </tbody>
  </table>
</div>

<script>
  import { scheduleVisibleStops } from "../../lib/activate-ri/listing";
  import { fetchPublicActivationStops } from "../../lib/activate-ri/public-stops-client";
  import {
    formatActivationDate,
    formatActivationTimeRange,
    timeZoneOptionForValue,
  } from "../../lib/activate-ri/time";

  document.querySelectorAll("[data-event-filters]").forEach(setupEventFilters);
  document.querySelectorAll<HTMLTableElement>("[data-live-schedule]").forEach(setupLiveSchedule);

  function setupEventFilters(root: Element): void {
    const filters = root as HTMLFormElement;
    const table = filters.nextElementSibling?.querySelector("[data-filtered-table]");
    const rows = Array.from(table?.querySelectorAll<HTMLElement>("[data-filter-row]") ?? []);
    const empty = table?.querySelector<HTMLElement>("[data-filter-empty]");
    const controls = Array.from(
      filters.querySelectorAll("[data-filter]"),
    ) as unknown as HTMLSelectElement[];
    const timezoneControls = Array.from(
      filters.querySelectorAll<HTMLInputElement>("[data-timezone]"),
    );

    const selectedTimezone = timeZoneOptionForValue(new URLSearchParams(window.location.search).get("timezone")).value;
    for (const control of timezoneControls) {
      control.checked = control.value === selectedTimezone;
    }

    const applyFilters = () => {
      const values = Object.fromEntries(
        controls.map((control) => [control.dataset.filter ?? "", control.value]),
      );
      let visibleCount = 0;

      for (const row of rows) {
        const isVisible =
          matchesList(row.dataset.modes, values.mode) &&
          matchesList(row.dataset.bands, values.band) &&
          matchesTimeline(row.dataset.date, values.timeline) &&
          matchesList(row.dataset.counties, values.county);

        row.hidden = !isVisible;
        visibleCount += isVisible ? 1 : 0;
      }

      if (empty) {
        empty.hidden = visibleCount > 0 || rows.length === 0;
      }
    };

    controls.forEach((control) => control.addEventListener("change", applyFilters));
    timezoneControls.forEach((control) => control.addEventListener("change", () => {
      if (!control.checked) {
        return;
      }

      updateTimezoneUrl(control.value);
      applyTimezone(table, control.value);
    }));
    applyTimezone(table, selectedTimezoneValue(timezoneControls) ?? "eastern");
    applyFilters();
  }

  function selectedTimezoneValue(controls: HTMLInputElement[]): string | undefined {
    return controls.find((control) => control.checked)?.value;
  }

  async function setupLiveSchedule(table: HTMLTableElement): Promise<void> {
    const body = table.querySelector("tbody");
    if (!body) {
      return;
    }

    let parks: Array<{ reference: string; name: string; counties?: string[] }> = [];
    try {
      parks = JSON.parse(table.dataset.parks ?? "[]");
    } catch {
      parks = [];
    }

    try {
      const stops = await fetchPublicActivationStops();
      const visibleStops = scheduleVisibleStops(stops);
      const filters = document.querySelector("[data-event-filters]") as HTMLFormElement | null;
      if (filters) {
        updateSelectOptions(filters, "mode", uniqueSortedValues(visibleStops.map((stop) => stop.modes)));
        updateSelectOptions(filters, "band", uniqueSortedValues(visibleStops.map((stop) => stop.bands)));
      }
      renderLiveSchedule(body, visibleStops, parks);
      if (filters) {
        setupEventFilters(filters);
      }
    } catch {
      renderScheduleUnavailable(body);
    }
  }

  function updateSelectOptions(
    filters: HTMLFormElement,
    filterName: "mode" | "band",
    values: string[],
  ): void {
    const control = filters.querySelector(`[data-filter="${filterName}"]`) as HTMLSelectElement | null;
    if (!control) {
      return;
    }

    const current = control.value;
    control.replaceChildren(new Option(filterName === "mode" ? "Any mode" : "Any band", "all"));
    for (const value of values) {
      control.appendChild(new Option(value, value));
    }
    control.value = values.includes(current) ? current : "all";
  }

  function uniqueSortedValues(values: string[][]): string[] {
    return [...new Set(values.flat().filter(Boolean))].sort((left, right) =>
      left.localeCompare(right),
    );
  }

  type PublicStop = {
    id: string;
    parkReference: string;
    plannedDate: string;
    startTime: string;
    endTime: string;
    activatorCallsign: string;
    bands: string[];
    modes: string[];
    status: string;
  };

  function renderLiveSchedule(
    body: HTMLTableSectionElement,
    stops: PublicStop[],
    parks: Array<{ reference: string; name: string; counties?: string[] }>,
  ): void {
    const parkByReference = new Map(parks.map((park) => [park.reference, park]));
    body.replaceChildren();

    if (stops.length === 0) {
      const row = document.createElement("tr");
      const cell = document.createElement("td");
      cell.colSpan = 7;
      cell.dataset.label = "Schedule";
      cell.textContent = "Approved activation windows will appear here after organizer review.";
      row.appendChild(cell);
      body.appendChild(row);
    } else {
      body.replaceChildren(...stops.map((stop) => createScheduleRow(stop, parkByReference)));
    }

    const empty = document.createElement("tr");
    empty.dataset.filterEmpty = "";
    empty.hidden = true;
    const emptyCell = document.createElement("td");
    emptyCell.colSpan = 7;
    emptyCell.dataset.label = "Schedule";
    emptyCell.textContent = "No scheduled activation windows match these filters.";
    empty.appendChild(emptyCell);
    body.appendChild(empty);
  }

  function renderScheduleUnavailable(body: HTMLTableSectionElement): void {
    const row = document.createElement("tr");
    const cell = document.createElement("td");
    cell.colSpan = 7;
    cell.dataset.label = "Schedule";
    cell.textContent = "Live schedule is unavailable. Try refreshing this page.";
    row.appendChild(cell);
    body.replaceChildren(row);
  }

  function createScheduleRow(
    stop: PublicStop,
    parkByReference: Map<string, { reference: string; name: string; counties?: string[] }>,
  ): HTMLTableRowElement {
    const park = parkByReference.get(stop.parkReference);
    const row = document.createElement("tr");
    row.dataset.filterRow = "";
    row.dataset.bands = stop.bands.join("|");
    row.dataset.counties = (park?.counties?.length ? park.counties : ["Unknown county"]).join("|");
    row.dataset.date = stop.plannedDate;
    row.dataset.modes = stop.modes.join("|");

    appendCell(row, "Date", formatActivationDate(stop));
    appendCell(row, "Time", `${stop.startTime}-${stop.endTime} UTC`);
    row.dataset.startTime = stop.startTime;
    row.dataset.endTime = stop.endTime;
    row.querySelector('[data-label="Date"]')?.setAttribute("data-schedule-date", "");
    row.querySelector('[data-label="Time"]')?.setAttribute("data-schedule-time", "");

    const parkHeader = document.createElement("th");
    parkHeader.scope = "row";
    parkHeader.dataset.label = "Park";
    parkHeader.append(park?.name ?? stop.parkReference);
    const reference = document.createElement("span");
    reference.textContent = stop.parkReference;
    parkHeader.appendChild(reference);
    row.appendChild(parkHeader);

    appendCell(
      row,
      "Activator",
      `${stop.activatorCallsign}${stop.modes.length > 0 ? ` (${stop.modes.join(", ")})` : ""}`,
    );
    appendCell(row, "Bands", stop.bands.length > 0 ? stop.bands.join(", ") : "TBD");
    appendCell(row, "Modes", stop.modes.length > 0 ? stop.modes.join(", ") : "TBD");
    appendCell(row, "Status", statusLabel(stop.status));

    return row;
  }

  function appendCell(row: HTMLTableRowElement, label: string, text: string): void {
    const cell = document.createElement("td");
    cell.dataset.label = label;
    cell.textContent = text;
    row.appendChild(cell);
  }

  function applyTimezone(table: Element | null | undefined, value: string): void {
    const option = timeZoneOptionForValue(value);
    table?.querySelectorAll<HTMLTableRowElement>("[data-filter-row]").forEach((row) => {
      const plannedDate = row.dataset.date;
      const startTime = row.dataset.startTime;
      const endTime = row.dataset.endTime;
      if (!plannedDate || !startTime || !endTime) {
        return;
      }

      const dateCell = row.querySelector<HTMLElement>("[data-schedule-date]");
      const timeCell = row.querySelector<HTMLElement>("[data-schedule-time]");
      if (dateCell) {
        dateCell.textContent = formatActivationDate({ plannedDate, startTime }, option);
      }
      if (timeCell) {
        timeCell.textContent = formatActivationTimeRange({ plannedDate, startTime, endTime }, option);
      }
    });
  }

  function updateTimezoneUrl(value: string): void {
    const url = new URL(window.location.href);
    url.searchParams.set("timezone", timeZoneOptionForValue(value).value);
    window.history.replaceState({}, "", url);
  }

  function statusLabel(status: string): string {
    const labels: Record<string, string> = {
      "pending-review": "Pending review",
      scheduled: "Scheduled",
      delayed: "Delayed",
      cancelled: "Cancelled",
      completed: "Completed",
    };

    return labels[status] ?? status;
  }

  function matchesList(value: string | undefined, filter: string | undefined): boolean {
    return !filter || filter === "all" || String(value ?? "").split("|").includes(filter);
  }

  function matchesTimeline(date: string | undefined, filter: string | undefined): boolean {
    if (!filter || filter === "all") {
      return true;
    }

    if (filter === "soft-start") {
      return date === "2026-09-10";
    }

    if (filter === "main") {
      return date === "2026-09-11" || date === "2026-09-12" || date === "2026-09-13";
    }

    return date === filter;
  }
</script>
