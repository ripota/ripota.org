<section class="admin-panel" aria-labelledby="admin-dashboard-title" data-admin-dashboard>
  <div class="admin-panel__header">
    <div>
      <p class="eyebrow">Organizer tools</p>
      <h2 id="admin-dashboard-title">Activation review queue</h2>
      <p class="lead">
        This admin queue is protected by Cloudflare Access in production.
      </p>
    </div>
    <button class="button" data-variant="primary" type="button" data-load-routes>
      Load pending submissions
    </button>
  </div>

  <p class="admin-status" data-admin-status aria-live="polite">
    Load the queue to review pending activation submissions.
  </p>
  <div class="admin-list" data-admin-list></div>
</section>

<script>
  type PendingStop = {
    park_reference?: unknown;
    planned_date?: unknown;
    start_time?: unknown;
    end_time?: unknown;
    bands?: unknown;
    modes?: unknown;
    public_notes?: unknown;
    organizer_notes?: unknown;
  };

  type PendingRoute = {
    id?: unknown;
    submitter_callsign?: unknown;
    submitter_name?: unknown;
    submitter_email?: unknown;
    submitter_phone?: unknown;
    club?: unknown;
    public_notes?: unknown;
    organizer_notes?: unknown;
    stops?: unknown;
  };

  type AdminResponse = {
    ok?: boolean;
    routes?: PendingRoute[];
    error?: string;
    message?: string;
  };

  const dashboard = document.querySelector("[data-admin-dashboard]");
  const loadButton = dashboard?.querySelector<HTMLButtonElement>("[data-load-routes]");
  const status = dashboard?.querySelector("[data-admin-status]");
  const list = dashboard?.querySelector("[data-admin-list]");

  loadButton?.addEventListener("click", () => {
    void loadPendingRoutes();
  });

  async function loadPendingRoutes() {
    if (!loadButton || !status || !list) {
      return;
    }

    loadButton.disabled = true;
    status.replaceChildren("Loading pending submissions...");
    list.replaceChildren();

    try {
      const response = await fetch("/api/activate-ri-2026/admin/routes", {
        headers: { accept: "application/json" },
      });
      const data = await parseResponse(response);

      if (!response.ok || !data.ok) {
        showRequestError(response, data, "Unable to load pending submissions.");
        return;
      }

      renderRoutes(Array.isArray(data.routes) ? data.routes : []);
    } catch {
      status.replaceChildren("Unable to load pending submissions. Please try again later.");
    } finally {
      loadButton.disabled = false;
    }
  }

  function renderRoutes(routes: PendingRoute[]) {
    if (!status || !list) {
      return;
    }

    list.replaceChildren();

    if (routes.length === 0) {
      status.replaceChildren("No pending submissions.");
      return;
    }

    status.replaceChildren(`${routes.length} pending submission${routes.length === 1 ? "" : "s"}.`);
    list.replaceChildren(...routes.map((route) => createRouteCard(route)));
  }

  function createRouteCard(route: PendingRoute) {
    const routeId = stringValue(route.id);
    const article = document.createElement("article");
    article.className = "admin-card";

    const body = document.createElement("div");
    body.className = "admin-card__body";

    const title = document.createElement("h3");
    title.textContent = stringValue(route.submitter_callsign) || "Unknown callsign";

    const meta = document.createElement("dl");
    meta.className = "admin-meta";
    addMeta(meta, "Name", stringValue(route.submitter_name) || "Not provided");
    addMeta(meta, "Email", stringValue(route.submitter_email) || "Not provided");
    addMeta(meta, "Phone", stringValue(route.submitter_phone) || "Not provided");
    addMeta(meta, "Club", stringValue(route.club) || "Not provided");
    addMeta(meta, "Public notes", stringValue(route.public_notes) || "None");
    addMeta(meta, "Organizer notes", stringValue(route.organizer_notes) || "None");

    body.appendChild(title);
    body.appendChild(meta);
    body.appendChild(createStopsSection(stopValues(route.stops)));

    const actions = document.createElement("div");
    actions.className = "admin-card__actions";

    const button = document.createElement("button");
    button.className = "button";
    button.dataset.variant = "primary";
    button.type = "button";
    button.textContent = "Approve";
    button.disabled = routeId.length === 0;
    button.addEventListener("click", () => {
      void approveRoute(routeId, article, button);
    });

    actions.appendChild(button);
    article.appendChild(body);
    article.appendChild(actions);

    return article;
  }

  function createStopsSection(stops: PendingStop[]) {
    const section = document.createElement("section");
    section.className = "admin-stops";

    const heading = document.createElement("h4");
    heading.textContent = `Stops (${stops.length})`;
    section.appendChild(heading);

    if (stops.length === 0) {
      const empty = document.createElement("p");
      empty.className = "admin-stops__empty";
      empty.textContent = "No stop details provided.";
      section.appendChild(empty);
      return section;
    }

    const list = document.createElement("div");
    list.className = "admin-stops__list";
    for (const stop of stops) {
      list.appendChild(createStopCard(stop));
    }
    section.appendChild(list);

    return section;
  }

  function createStopCard(stop: PendingStop) {
    const article = document.createElement("article");
    article.className = "admin-stop";

    const title = document.createElement("h5");
    title.textContent = stringValue(stop.park_reference) || "Unknown park";

    const meta = document.createElement("dl");
    meta.className = "admin-meta admin-meta--compact";
    addMeta(meta, "Date", stringValue(stop.planned_date) || "Not provided");
    addMeta(meta, "Time", timeRange(stop));
    addMeta(meta, "Bands", arrayValue(stop.bands).join(", ") || "Not provided");
    addMeta(meta, "Modes", arrayValue(stop.modes).join(", ") || "Not provided");
    addMeta(meta, "Public notes", stringValue(stop.public_notes) || "None");
    addMeta(meta, "Organizer notes", stringValue(stop.organizer_notes) || "None");

    article.appendChild(title);
    article.appendChild(meta);

    return article;
  }

  function addMeta(list: HTMLDListElement, label: string, value: string) {
    const term = document.createElement("dt");
    term.textContent = label;
    const description = document.createElement("dd");
    description.textContent = value;
    list.appendChild(term);
    list.appendChild(description);
  }

  function stopValues(value: unknown): PendingStop[] {
    return Array.isArray(value)
      ? value.filter((item): item is PendingStop => typeof item === "object" && item !== null)
      : [];
  }

  function arrayValue(value: unknown): string[] {
    return Array.isArray(value)
      ? value.filter((item): item is string => typeof item === "string")
      : [];
  }

  function timeRange(stop: PendingStop): string {
    const start = stringValue(stop.start_time);
    const end = stringValue(stop.end_time);

    if (start && end) {
      return `${start}-${end}`;
    }

    return start || end || "Not provided";
  }

  async function approveRoute(routeId: string, card: HTMLElement, button: HTMLButtonElement) {
    if (!status || !list || routeId.length === 0) {
      return;
    }

    button.disabled = true;
    status.replaceChildren("Approving submission...");

    try {
      const response = await fetch(`/api/activate-ri-2026/admin/routes/${encodeURIComponent(routeId)}/approve`, {
        method: "POST",
        headers: { accept: "application/json" },
      });
      const data = await parseResponse(response);

      if (!response.ok || !data.ok) {
        showRequestError(response, data, "Unable to approve submission.");
        button.disabled = false;
        return;
      }

      const nextFocusTarget =
        card.nextElementSibling?.querySelector<HTMLButtonElement>("button") ??
        card.previousElementSibling?.querySelector<HTMLButtonElement>("button") ??
        loadButton;

      card.remove();
      nextFocusTarget?.focus();
      if (list.children.length === 0) {
        status.replaceChildren("No pending submissions.");
      } else {
        status.replaceChildren("Submission approved.");
      }
    } catch {
      status.replaceChildren("Unable to approve submission. Please try again later.");
      button.disabled = false;
    }
  }

  async function parseResponse(response: Response): Promise<AdminResponse> {
    const contentType = response.headers.get("content-type") ?? "";

    if (!contentType.includes("application/json")) {
      return {};
    }

    return response.json();
  }

  function showRequestError(response: Response, data: AdminResponse, fallback: string) {
    if (!status) {
      return;
    }

    if (response.status === 401 || response.status === 403) {
      status.replaceChildren(
        "Admin access is protected. Sign in with an authorized Cloudflare Access account, then try again.",
      );
      return;
    }

    status.replaceChildren(data.error ?? data.message ?? fallback);
  }

  function stringValue(value: unknown): string {
    return typeof value === "string" ? value : "";
  }
</script>
