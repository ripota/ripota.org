<section class="admin-panel" aria-labelledby="admin-dashboard-title" data-admin-dashboard>
  <div class="admin-panel__header">
    <div>
      <p class="eyebrow">Organizer tools</p>
      <h2 id="admin-dashboard-title">Activation review queue</h2>
      <p class="lead">
        This admin queue is protected by Cloudflare Access in production.
      </p>
    </div>
    <button class="button" data-variant="primary" type="button" data-load-plans>
      Refresh pending submissions
    </button>
  </div>

  <p class="admin-status" data-admin-status aria-live="polite">
    Loading pending submissions...
  </p>
  <div class="admin-list" data-admin-list></div>

  <section class="admin-activity" aria-labelledby="admin-activity-title">
    <div class="admin-panel__header">
      <div>
        <h3 id="admin-activity-title">Activity log</h3>
        <p class="lead">Recent submissions, approvals, email events, and activator changes.</p>
      </div>
      <button class="button" data-variant="light" type="button" data-load-activity>
        Refresh activity
      </button>
    </div>
    <p class="admin-status" data-activity-status aria-live="polite">
      Loading activity...
    </p>
    <div class="admin-list" data-activity-list></div>
  </section>
</section>

<script>
  import { activityDetailEntries } from "../../lib/activate-ri/activity-details";

  type PendingStop = {
    park_reference?: unknown;
    planned_date?: unknown;
    start_time?: unknown;
    end_time?: unknown;
    bands?: unknown;
    modes?: unknown;
    public_notes?: unknown;
    organizer_notes?: unknown;
  };

  type PendingPlan = {
    id?: unknown;
    submitter_callsign?: unknown;
    submitter_name?: unknown;
    submitter_email?: unknown;
    submitter_phone?: unknown;
    club?: unknown;
    public_notes?: unknown;
    organizer_notes?: unknown;
    stops?: unknown;
  };

  type AdminResponse = {
    ok?: boolean;
    plans?: PendingPlan[];
    events?: ActivityEvent[];
    error?: string;
    message?: string;
    editUrl?: string;
  };

  type ActivityEvent = {
    action?: unknown;
    actor_email?: unknown;
    actor_type?: unknown;
    created_at?: unknown;
    details?: unknown;
    plan_id?: unknown;
    stop_id?: unknown;
    summary?: unknown;
  };

  const dashboard = document.querySelector("[data-admin-dashboard]");
  const loadButton = dashboard?.querySelector<HTMLButtonElement>("[data-load-plans]");
  const activityButton = dashboard?.querySelector<HTMLButtonElement>("[data-load-activity]");
  const status = dashboard?.querySelector("[data-admin-status]");
  const activityStatus = dashboard?.querySelector("[data-activity-status]");
  const list = dashboard?.querySelector("[data-admin-list]");
  const activityList = dashboard?.querySelector("[data-activity-list]");

  loadButton?.addEventListener("click", () => {
    void loadPendingPlans();
  });
  activityButton?.addEventListener("click", () => {
    void loadActivity();
  });
  void loadPendingPlans();
  void loadActivity();

  async function loadPendingPlans() {
    if (!loadButton || !status || !list) {
      return;
    }

    loadButton.disabled = true;
    status.replaceChildren("Loading pending submissions...");
    list.replaceChildren();

    try {
      const response = await fetch("/api/activate-ri-2026/admin/plans", {
        headers: { accept: "application/json" },
      });
      const data = await parseResponse(response);

      if (!response.ok || !data.ok) {
        showRequestError(response, data, "Unable to load pending submissions.");
        return;
      }

      renderPlans(Array.isArray(data.plans) ? data.plans : []);
    } catch {
      status.replaceChildren("Unable to load pending submissions. Please try again later.");
    } finally {
      loadButton.disabled = false;
    }
  }

  function renderPlans(plans: PendingPlan[]) {
    if (!status || !list) {
      return;
    }

    list.replaceChildren();

    if (plans.length === 0) {
      status.replaceChildren("No pending submissions.");
      return;
    }

    status.replaceChildren(`${plans.length} pending submission${plans.length === 1 ? "" : "s"}.`);
    list.replaceChildren(...plans.map((plan) => createPlanCard(plan)));
  }

  function createPlanCard(plan: PendingPlan) {
    const planId = stringValue(plan.id);
    const article = document.createElement("article");
    article.className = "admin-card";

    const body = document.createElement("div");
    body.className = "admin-card__body";

    const title = document.createElement("h3");
    title.textContent = stringValue(plan.submitter_callsign) || "Unknown callsign";

    const meta = document.createElement("dl");
    meta.className = "admin-meta";
    addMeta(meta, "Name", stringValue(plan.submitter_name) || "Not provided");
    addMeta(meta, "Email", stringValue(plan.submitter_email) || "Not provided");
    addMeta(meta, "Phone", stringValue(plan.submitter_phone) || "Not provided");
    addMeta(meta, "Club", stringValue(plan.club) || "Not provided");
    addMeta(meta, "Public notes", stringValue(plan.public_notes) || "None");
    addMeta(meta, "Organizer notes", stringValue(plan.organizer_notes) || "None");

    body.appendChild(title);
    body.appendChild(meta);
    body.appendChild(createStopsSection(stopValues(plan.stops)));

    const actions = document.createElement("div");
    actions.className = "admin-card__actions";

    const button = document.createElement("button");
    button.className = "button";
    button.dataset.variant = "primary";
    button.type = "button";
    button.textContent = "Approve";
    button.setAttribute("aria-label", approvalLabel(plan));
    button.disabled = planId.length === 0;
    button.addEventListener("click", () => {
      void approvePlan(planId, article, button);
    });

    actions.appendChild(button);
    article.appendChild(body);
    article.appendChild(actions);

    return article;
  }

  function createStopsSection(stops: PendingStop[]) {
    const section = document.createElement("section");
    section.className = "admin-stops";

    const heading = document.createElement("h4");
    heading.textContent = `Stops (${stops.length})`;
    section.appendChild(heading);

    if (stops.length === 0) {
      const empty = document.createElement("p");
      empty.className = "admin-stops__empty";
      empty.textContent = "No stop details provided.";
      section.appendChild(empty);
      return section;
    }

    const list = document.createElement("div");
    list.className = "admin-stops__list";
    for (const stop of stops) {
      list.appendChild(createStopCard(stop));
    }
    section.appendChild(list);

    return section;
  }

  function createStopCard(stop: PendingStop) {
    const article = document.createElement("article");
    article.className = "admin-stop";

    const title = document.createElement("h5");
    title.textContent = stringValue(stop.park_reference) || "Unknown park";

    const meta = document.createElement("dl");
    meta.className = "admin-meta admin-meta--compact";
    addMeta(meta, "Date", stringValue(stop.planned_date) || "Not provided");
    addMeta(meta, "Time", timeRange(stop));
    addMeta(meta, "Bands", arrayValue(stop.bands).join(", ") || "Not provided");
    addMeta(meta, "Modes", arrayValue(stop.modes).join(", ") || "Not provided");
    addMeta(meta, "Public notes", stringValue(stop.public_notes) || "None");
    addMeta(meta, "Organizer notes", stringValue(stop.organizer_notes) || "None");

    article.appendChild(title);
    article.appendChild(meta);

    return article;
  }

  function addMeta(list: HTMLDListElement, label: string, value: string) {
    const term = document.createElement("dt");
    term.textContent = label;
    const description = document.createElement("dd");
    description.textContent = value;
    list.appendChild(term);
    list.appendChild(description);
  }

  function stopValues(value: unknown): PendingStop[] {
    return Array.isArray(value)
      ? value.filter((item): item is PendingStop => typeof item === "object" && item !== null)
      : [];
  }

  function arrayValue(value: unknown): string[] {
    return Array.isArray(value)
      ? value.filter((item): item is string => typeof item === "string")
      : [];
  }

  function timeRange(stop: PendingStop): string {
    const start = stringValue(stop.start_time);
    const end = stringValue(stop.end_time);

    if (start && end) {
      return `${start}-${end}`;
    }

    return start || end || "Not provided";
  }

  function approvalLabel(plan: PendingPlan): string {
    const callsign = stringValue(plan.submitter_callsign);
    const name = stringValue(plan.submitter_name);
    const submitter = [callsign, name].filter(Boolean).join(" - ");

    return submitter ? `Approve ${submitter}` : "Approve submission";
  }

  async function approvePlan(planId: string, card: HTMLElement, button: HTMLButtonElement) {
    if (!status || !list || planId.length === 0) {
      return;
    }

    button.disabled = true;
    status.replaceChildren("Approving submission...");

    try {
      const response = await fetch(`/api/activate-ri-2026/admin/plans/${encodeURIComponent(planId)}/approve`, {
        method: "POST",
        headers: { accept: "application/json" },
      });
      const data = await parseResponse(response);

      if (!response.ok || !data.ok) {
        showRequestError(response, data, "Unable to approve submission.");
        button.disabled = false;
        return;
      }

      const nextFocusTarget =
        card.nextElementSibling?.querySelector<HTMLButtonElement>("button") ??
        card.previousElementSibling?.querySelector<HTMLButtonElement>("button") ??
        loadButton;

      card.remove();
      nextFocusTarget?.focus();
      showApprovalSuccess(list.children.length);
      void loadActivity();
    } catch {
      status.replaceChildren("Unable to approve submission. Please try again later.");
      button.disabled = false;
    }
  }

  function showApprovalSuccess(remainingCount: number) {
    if (!status) {
      return;
    }

    status.replaceChildren(
      remainingCount === 0 ? "No pending submissions." : "Submission approved.",
    );
  }

  async function loadActivity() {
    if (!activityButton || !activityStatus || !activityList) {
      return;
    }

    activityButton.disabled = true;
    activityStatus.replaceChildren("Loading activity...");
    activityList.replaceChildren();

    try {
      const response = await fetch("/api/activate-ri-2026/admin/activity", {
        headers: { accept: "application/json" },
      });
      const data = await parseResponse(response);

      if (!response.ok || !data.ok) {
        showActivityError(response, data, "Unable to load activity.");
        return;
      }

      const events = Array.isArray(data.events) ? data.events : [];
      renderActivity(events);
    } catch {
      activityStatus.replaceChildren("Unable to load activity. Please try again later.");
    } finally {
      activityButton.disabled = false;
    }
  }

  function renderActivity(events: ActivityEvent[]) {
    if (!activityStatus || !activityList) {
      return;
    }

    const visibleEvents = compactActivityEvents(events);
    activityList.replaceChildren();
    if (visibleEvents.length === 0) {
      activityStatus.replaceChildren("No activity events yet.");
      return;
    }

    activityStatus.replaceChildren(`${visibleEvents.length} recent event${visibleEvents.length === 1 ? "" : "s"}.`);
    activityList.replaceChildren(...visibleEvents.map(createActivityCard));
  }

  function compactActivityEvents(events: ActivityEvent[]): ActivityEvent[] {
    return events.filter((event) => !hasCanonicalActivityEvent(event, events));
  }

  function hasCanonicalActivityEvent(event: ActivityEvent, events: ActivityEvent[]): boolean {
    const action = stringValue(event.action);
    const planId = stringValue(event.plan_id);
    if (!planId || !routineEmailActionAnchors.has(action)) {
      return false;
    }

    const eventTime = Date.parse(stringValue(event.created_at));
    if (!Number.isFinite(eventTime)) {
      return false;
    }

    const anchorActions = routineEmailActionAnchors.get(action) ?? new Set<string>();
    return events.some((candidate) => {
      if (candidate === event || stringValue(candidate.plan_id) !== planId) {
        return false;
      }

      const candidateAction = stringValue(candidate.action);
      if (!anchorActions.has(candidateAction)) {
        return false;
      }

      const candidateTime = Date.parse(stringValue(candidate.created_at));
      return Number.isFinite(candidateTime) && Math.abs(candidateTime - eventTime) <= 2000;
    });
  }

  function createActivityCard(event: ActivityEvent) {
    const article = document.createElement("article");
    article.className = "activity-row";

    const body = document.createElement("div");
    body.className = "activity-row__body";

    const header = document.createElement("div");
    header.className = "activity-row__header";

    const summary = document.createElement("p");
    summary.className = "activity-row__summary";
    summary.textContent = stringValue(event.summary) || "No summary provided.";

    const action = document.createElement("span");
    action.className = "activity-row__action";
    action.textContent = formatAction(stringValue(event.action));

    const meta = document.createElement("p");
    meta.className = "activity-row__meta";
    meta.textContent = [
      formatEventTime(stringValue(event.created_at)),
      actorLabel(event),
    ].filter(Boolean).join(" by ");

    header.appendChild(summary);
    header.appendChild(action);
    body.appendChild(header);
    body.appendChild(meta);

    const details = createActivityDetails(event.details);
    if (details) {
      body.appendChild(details);
    }

    article.appendChild(body);

    return article;
  }

  function createActivityDetails(details: unknown): HTMLElement | null {
    if (!isRecord(details)) {
      return null;
    }

    const entries = activityDetailEntries(details);
    if (entries.length === 0) {
      return null;
    }

    const list = document.createElement("dl");
    list.className = "activity-details";
    for (const [label, value] of entries) {
      addMeta(list, label, value);
    }

    return list;
  }

  function actorLabel(event: ActivityEvent): string {
    return [stringValue(event.actor_type), stringValue(event.actor_email)]
      .filter(Boolean)
      .join(" - ") || "system";
  }

  function formatAction(action: string): string {
    return action.replaceAll("-", " ") || "activity";
  }

  const routineEmailActionAnchors = new Map<string, Set<string>>([
    ["edit-link-sent", new Set(["plan-created"])],
    ["approval-email-sent", new Set(["plan-approved"])],
    [
      "activator-notification-sent",
      new Set([
        "plan-updated",
        "stop-updated",
        "stop-added",
        "stop-withdrawn",
        "plan-cancelled",
        "stop-cancelled",
      ]),
    ],
  ]);

  function isRecord(value: unknown): value is Record<string, unknown> {
    return typeof value === "object" && value !== null && !Array.isArray(value);
  }

  async function parseResponse(response: Response): Promise<AdminResponse> {
    const contentType = response.headers.get("content-type") ?? "";

    if (!contentType.includes("application/json")) {
      return {};
    }

    return response.json();
  }

  function showRequestError(response: Response, data: AdminResponse, fallback: string) {
    if (!status) {
      return;
    }

    if (response.status === 401 || response.status === 403) {
      status.replaceChildren(
        "Admin access is protected. Sign in with an authorized Cloudflare Access account, then try again.",
      );
      return;
    }

    status.replaceChildren(data.error ?? data.message ?? fallback);
  }

  function showActivityError(response: Response, data: AdminResponse, fallback: string) {
    if (!activityStatus) {
      return;
    }

    if (response.status === 401 || response.status === 403) {
      activityStatus.replaceChildren(
        "Admin access is protected. Sign in with an authorized Cloudflare Access account, then try again.",
      );
      return;
    }

    activityStatus.replaceChildren(data.error ?? data.message ?? fallback);
  }

  function formatEventTime(value: string): string {
    if (!value) {
      return "Not provided";
    }

    const date = new Date(value);
    return Number.isNaN(date.valueOf()) ? value : date.toLocaleString();
  }

  function stringValue(value: unknown): string {
    return typeof value === "string" ? value : "";
  }
</script>
