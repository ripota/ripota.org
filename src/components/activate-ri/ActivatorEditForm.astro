---
import ActivateRiIdentityFields from "./ActivateRiIdentityFields.astro";
import ActivateRiStopCard from "./ActivateRiStopCard.astro";

const turnstileSiteKey =
  import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
---

<script
  is:inline
  src="https://challenges.cloudflare.com/turnstile/v0/api.js"
  async
  defer
></script>

<form class="event-form" data-activator-edit novalidate>
  <div class="admin-panel__header">
    <div>
      <p class="eyebrow">Activator edits</p>
      <h2 id="activator-edit-title">Edit your activation plan</h2>
      <p class="lead">
        This private link lets you update your Activate All RI 2026 plan.
      </p>
    </div>
  </div>

  <p class="form-help form-required-note"><span class="required-marker" aria-hidden="true">*</span> Required fields</p>
  <p class="form-status" data-edit-status aria-live="polite">Loading plan...</p>

  <label data-plan-picker hidden>
    Activation plan
    <select data-plan-select></select>
  </label>

  <div data-edit-fields hidden>
    <ActivateRiIdentityFields clubDatalistId="activate-ri-edit-clubs" />
  </div>
  <datalist id="activate-ri-edit-clubs" data-club-options></datalist>

  <div class="activation-stops" data-edit-stops hidden></div>

  <div class="form-field" data-edit-organizer-notes hidden>
    <span class="field-label-row">
      <span class="form-label">Notes for organizers</span>
      <span class="help-popover">
        <button
          class="help-popover__button"
          type="button"
          aria-label="Help for organizer notes field"
        >?</button>
        <span class="help-popover__bubble" role="tooltip">
          These notes are for coordinators and are not shown on the public
          schedule.
        </span>
      </span>
    </span>
    <textarea
      name="organizerNotes"
      rows="3"
      aria-describedby="activate-ri-organizer-notes-help"
    ></textarea>
    <span id="activate-ri-organizer-notes-help" class="form-help">
      Use this for coordinator context, special constraints, or review notes.
    </span>
  </div>

  <p class="form-help" data-edit-frequency-note hidden>
    Frequencies are not collected here. Please use normal POTA spotting when
    your activation begins.
  </p>

  <div
    class="cf-turnstile"
    data-sitekey={turnstileSiteKey}
    data-action="turnstile-spin-v1"
    data-edit-turnstile
    hidden
  />

  <div class="form-actions" data-edit-actions hidden>
    <button class="button" data-variant="light" type="button" data-add-stop>
      Add another park
    </button>
    <button class="button" data-variant="light" type="button" data-cancel-plan>
      Cancel plan
    </button>
    <button class="button" data-variant="primary" type="submit" data-save-plan>
      Save changes
    </button>
  </div>
</form>

<dialog class="form-confirmation" data-edit-confirmation>
  <div class="form-confirmation__body">
    <p class="eyebrow">Changes saved</p>
    <h2>Your activation plan was updated</h2>
    <p>
      The latest version is saved. You can keep editing this plan or return to
      the event overview.
    </p>
    <div class="form-actions">
      <a class="button" data-variant="primary" href="/activate-ri-2026/" data-edit-confirmation-overview>
        Back to event overview
      </a>
    </div>
  </div>
</dialog>

<template data-stop-template>
  <ActivateRiStopCard includeStopId={true} title="Activation stop" />
</template>

<script>
  import { timeBlockToRange } from "../../lib/activate-ri/time-blocks";

  type StopDto = {
    id?: unknown;
    park_reference?: unknown;
    planned_date?: unknown;
    start_time?: unknown;
    end_time?: unknown;
    bands?: unknown;
    modes?: unknown;
    public_notes?: unknown;
  };

  type PlanDto = {
    id?: unknown;
    submitter_callsign?: unknown;
    submitter_name?: unknown;
    submitter_email?: unknown;
    club?: unknown;
    public_notes?: unknown;
    organizer_notes?: unknown;
    stops?: unknown;
  };

  const editForm = document.querySelector("[data-activator-edit]") as HTMLFormElement | null;
  const editStatus = editForm?.querySelector("[data-edit-status]");
  const editFields = editForm?.querySelector("[data-edit-fields]") as HTMLElement | null | undefined;
  const editStops = editForm?.querySelector("[data-edit-stops]") as HTMLElement | null | undefined;
  const editActions = editForm?.querySelector("[data-edit-actions]") as HTMLElement | null | undefined;
  const editOrganizerNotes = editForm?.querySelector("[data-edit-organizer-notes]") as HTMLElement | null | undefined;
  const editFrequencyNote = editForm?.querySelector("[data-edit-frequency-note]") as HTMLElement | null | undefined;
  const editTurnstile = editForm?.querySelector("[data-edit-turnstile]") as HTMLElement | null | undefined;
  const editConfirmation = document.querySelector("[data-edit-confirmation]") as HTMLDialogElement | null;
  const savePlanButton = editForm?.querySelector("[data-save-plan]") as HTMLButtonElement | null | undefined;
  const planPicker = editForm?.querySelector("[data-plan-picker]") as HTMLElement | null | undefined;
  const planSelect = editForm?.querySelector("[data-plan-select]") as HTMLSelectElement | null | undefined;
  const stopTemplate = document.querySelector("[data-stop-template]") as HTMLTemplateElement | null;
  let isSaving = false;
  let plans: PlanDto[] = [];
  let selectedPlanId = "";

  setupCallsignFields();
  void populateClubDatalist("activate-ri-edit-clubs");
  void loadPlan();

  document.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof Node)) {
      return;
    }

    document.querySelectorAll<HTMLElement>("[data-park-combobox]").forEach((combo) => {
      if (!combo.contains(target)) {
        setParkPopupOpen(combo, false);
      }
    });

    document.querySelectorAll<HTMLElement>("[data-multi-select]").forEach((multiSelect) => {
      if (!multiSelect.contains(target)) {
        setMultiSelectOpen(multiSelect, false);
      }
    });
  });

  document.addEventListener("activate-ri:add-park", (event) => {
    const reference = (event as CustomEvent<{ reference?: string }>).detail?.reference;
    if (!reference) {
      return;
    }

    addParkReferenceToForm(reference);
  });

  editForm?.addEventListener("submit", async (event) => {
    event.preventDefault();

    if (!editForm || isSaving) {
      return;
    }

    isSaving = true;
    if (savePlanButton) {
      savePlanButton.disabled = true;
    }
    setEditStatus("Saving changes...");

    try {
      const response = await fetch(selectedPlanUrl(), {
        method: "PATCH",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(formToPayload(new FormData(editForm))),
      });
      const data = await parseResponse(response);

      if (!response.ok || !data.ok) {
        setEditStatus(data.errors?.join(" ") ?? data.error ?? "Unable to save changes.", "error");
        resetTurnstile();
        return;
      }

      setEditStatus("Changes saved. Your activation plan was updated.", "success");
      resetTurnstile();
      await loadPlan(false);
      showEditConfirmation();
    } catch {
      setEditStatus("Unable to save changes. Please try again later.", "error");
      resetTurnstile();
    } finally {
      isSaving = false;
      if (savePlanButton) {
        savePlanButton.disabled = false;
      }
    }
  });

  editForm?.querySelector("[data-add-stop]")?.addEventListener("click", () => {
    appendStop({})?.querySelector<HTMLInputElement>("[data-park-input]")?.focus();
  });

  editForm?.querySelector("[data-cancel-plan]")?.addEventListener("click", async () => {
    if (!window.confirm("Cancel this activation plan? This will mark active stops as cancelled.")) {
      return;
    }

    editStatus?.replaceChildren("Cancelling plan...");
    try {
      const response = await fetch(`${selectedPlanUrl()}/cancel`, {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({
          cancelReason: "Cancelled by activator.",
          turnstileToken: new FormData(editForm ?? undefined).get("cf-turnstile-response"),
        }),
      });
      const data = await parseResponse(response);

      if (!response.ok || !data.ok) {
        editStatus?.replaceChildren(data.errors?.join(" ") ?? data.error ?? "Unable to cancel plan.");
        resetTurnstile();
        return;
      }

      editStatus?.replaceChildren("Plan cancelled.");
      resetTurnstile();
      await loadPlan(false);
    } catch {
      editStatus?.replaceChildren("Unable to cancel plan. Please try again later.");
      resetTurnstile();
    }
  });

  async function loadPlan(showLoading = true): Promise<void> {
    if (!editForm || !editFields || !editStops || !editActions) {
      return;
    }

    const token = editToken();
    if (!token) {
      editStatus?.replaceChildren("This edit link is missing its private token.");
      return;
    }

    if (showLoading) {
      editStatus?.replaceChildren("Loading plan...");
    }

    try {
      const response = await fetch(apiUrl(), {
        headers: { accept: "application/json" },
      });
      const data = await parseResponse(response);

      if (!response.ok || !data.ok || !Array.isArray(data.plans)) {
        editStatus?.replaceChildren(data.error ?? "Unable to load this edit link.");
        return;
      }

      plans = data.plans.filter((plan): plan is PlanDto => typeof plan === "object" && plan !== null);
      if (plans.length === 0) {
        editStatus?.replaceChildren("No activation plans found for this edit link.");
        return;
      }

      const previousPlanId = selectedPlanId;
      const selectedPlan = plans.find((plan) => stringValue(plan.id) === previousPlanId) ?? plans[0];
      selectedPlanId = stringValue(selectedPlan?.id);

      renderPlanPicker();
      renderSelectedPlan();
      editFields.hidden = false;
      editStops.hidden = false;
      editActions.hidden = false;
      editOrganizerNotes?.removeAttribute("hidden");
      editFrequencyNote?.removeAttribute("hidden");
      editTurnstile?.removeAttribute("hidden");
      if (showLoading) {
        editStatus?.replaceChildren("Loaded. Make any changes and save.");
      }
    } catch {
      editStatus?.replaceChildren("Unable to load this edit link.");
    }
  }

  planSelect?.addEventListener("change", () => {
    selectedPlanId = planSelect.value;
    renderSelectedPlan();
    editStatus?.replaceChildren("Loaded. Make any changes and save.");
  });

  function renderPlanPicker(): void {
    if (!planPicker || !planSelect) {
      return;
    }

    planPicker.hidden = plans.length < 2;
    planSelect.replaceChildren(
      ...plans.map((plan, index) => {
        const option = document.createElement("option");
        option.value = stringValue(plan.id);
        option.textContent = planLabel(plan, index);
        option.selected = option.value === selectedPlanId;

        return option;
      }),
    );
  }

  function renderSelectedPlan(): void {
    const plan = plans.find((candidate) => stringValue(candidate.id) === selectedPlanId) ?? plans[0];
    if (plan) {
      selectedPlanId = stringValue(plan.id);
      renderPlan(plan);
    }
  }

  function planLabel(plan: PlanDto, index: number): string {
    const stops = Array.isArray(plan.stops) ? plan.stops.length : 0;
    const callsign = stringValue(plan.submitter_callsign) || `Plan ${index + 1}`;

    return `${callsign} - ${stops} stop${stops === 1 ? "" : "s"}`;
  }

  function renderPlan(plan: PlanDto): void {
    setNamedValue("submitterCallsign", stringValue(plan.submitter_callsign).toUpperCase());
    setNamedValue("submitterName", stringValue(plan.submitter_name));
    setNamedValue("submitterEmail", stringValue(plan.submitter_email));
    setNamedValue("club", stringValue(plan.club));
    setNamedValue("organizerNotes", stringValue(plan.organizer_notes));

    editStops?.replaceChildren();
    const stops = Array.isArray(plan.stops)
      ? plan.stops.filter((stop): stop is StopDto => typeof stop === "object" && stop !== null)
      : [];
    for (const stop of stops) {
      appendStop(stop);
    }
    if (stops.length === 0) {
      appendStop({});
    }
    setupStopCards();
  }

  function appendStop(stop: StopDto): HTMLElement | null {
    if (!stopTemplate || !editStops) {
      return null;
    }

    const node = stopTemplate.content.firstElementChild?.cloneNode(true) as HTMLElement | undefined;
    if (!node) {
      return null;
    }

    setValue(node, "[data-stop-id]", stringValue(stop.id));
    selectParkReference(node, stringValue(stop.park_reference));
    setValue(node, "[data-planned-date]", stringValue(stop.planned_date) || "2026-09-11");
    setValue(node, "[data-time-block]", timeBlockValue(stop));
    setSelectedValues(node.querySelector<HTMLElement>("[data-bands]"), arrayValue(stop.bands));
    setSelectedValues(node.querySelector<HTMLElement>("[data-modes]"), arrayValue(stop.modes));
    setValue(node, "[data-public-notes]", stringValue(stop.public_notes));
    editStops.appendChild(node);
    setupStopCards();
    return node;
  }

  function setupStopCards(): void {
    const stops = Array.from(document.querySelectorAll<HTMLElement>("[data-stop-card]"));
    stops.forEach((stop, index) => {
      stop.querySelector("[data-stop-title]")?.replaceChildren(`Activation stop ${index + 1}`);
      const removeButton = stop.querySelector("[data-remove-stop]") as HTMLButtonElement | null;
      if (removeButton) {
        removeButton.hidden = stops.length === 1;
        removeButton.onclick = () => {
          stop.remove();
          setupStopCards();
        };
      }

      const parkInput = stop.querySelector<HTMLInputElement>("[data-park-input]");
      const parkReference = stop.querySelector<HTMLInputElement>("[data-park-reference]");
      const parkCombobox = stop.querySelector<HTMLElement>("[data-park-combobox]");
      if (parkInput && parkReference && parkCombobox) {
        const syncParkReference = () => {
          parkReference.value = selectedParkReference(parkInput.value.trim(), parkCombobox);
          filterParkOptions(parkCombobox, parkInput.value);
        };

        parkInput.onfocus = () => {
          filterParkOptions(parkCombobox, parkInput.value);
          setParkPopupOpen(parkCombobox, true);
        };
        parkInput.oninput = syncParkReference;
        parkInput.onchange = syncParkReference;
        syncParkReference();

        parkCombobox.querySelectorAll<HTMLElement>("[data-park-option]").forEach((option) => {
          option.onclick = () => {
            parkInput.value = option.dataset.label ?? "";
            parkReference.value = option.dataset.reference ?? "";
            setParkPopupOpen(parkCombobox, false);
          };
        });
      }

      stop.querySelectorAll<HTMLElement>("[data-multi-select]").forEach((multiSelect) => {
        const toggle = multiSelect.querySelector<HTMLButtonElement>("[data-multi-toggle]");
        if (toggle) {
          toggle.onclick = () => {
            setMultiSelectOpen(multiSelect, toggle.getAttribute("aria-expanded") !== "true");
          };
        }

        multiSelect.querySelectorAll<HTMLInputElement>("[data-multi-option]").forEach((option) => {
          option.onchange = () => updateMultiSelectLabel(multiSelect);
        });
        updateMultiSelectLabel(multiSelect);
      });
    });
  }

  function formToPayload(data: FormData) {
    return {
      submitterCallsign: uppercaseFormValue(data.get("submitterCallsign")),
      submitterName: data.get("submitterName"),
      submitterEmail: data.get("submitterEmail"),
      club: data.get("club"),
      publicNotes: "",
      organizerNotes: data.get("organizerNotes"),
      turnstileToken: data.get("cf-turnstile-response"),
      stops: Array.from(document.querySelectorAll<HTMLElement>("[data-stop-card]")).map((stop) => {
        const timeBlock = (stop.querySelector("[data-time-block]") as HTMLSelectElement | null)?.value ?? "";
        const timeRange = timeBlockToRange(timeBlock) ?? { startTime: "", endTime: "" };

        return {
          id: (stop.querySelector("[data-stop-id]") as HTMLInputElement | null)?.value,
          parkReference: (stop.querySelector("[data-park-reference]") as HTMLInputElement | null)?.value,
          plannedDate: (stop.querySelector("[data-planned-date]") as HTMLSelectElement | null)?.value,
          startTime: timeRange.startTime,
          endTime: timeRange.endTime,
          bands: selectedValues(stop.querySelector<HTMLElement>("[data-bands]")),
          modes: selectedValues(stop.querySelector<HTMLElement>("[data-modes]")),
          publicNotes: (stop.querySelector("[data-public-notes]") as HTMLTextAreaElement | null)?.value ?? "",
        };
      }),
    };
  }

  function uppercaseFormValue(value: FormDataEntryValue | null): FormDataEntryValue | null {
    return typeof value === "string" ? value.toUpperCase() : value;
  }

  function setupCallsignFields(): void {
    editForm?.querySelectorAll<HTMLInputElement>(".callsign-input").forEach((field) => {
      const uppercaseValue = () => {
        field.value = field.value.toUpperCase();
      };

      field.addEventListener("input", uppercaseValue);
      field.addEventListener("change", uppercaseValue);
      uppercaseValue();
    });
  }

  async function populateClubDatalist(id: string): Promise<void> {
    const datalist = document.getElementById(id);
    if (!datalist) {
      return;
    }

    try {
      const response = await fetch("/api/activate-ri-2026/public/clubs", {
        headers: { accept: "application/json" },
      });
      const body = await response.json() as { clubs?: unknown };
      const clubs = Array.isArray(body.clubs)
        ? body.clubs.filter((club): club is string => typeof club === "string")
        : [];

      datalist.replaceChildren(
        ...clubs.map((club) => {
          const option = document.createElement("option");
          option.value = club;
          return option;
        }),
      );
    } catch {
      datalist.replaceChildren();
    }
  }

  function addParkReferenceToForm(reference: string): void {
    const targetStop = firstEmptyStopCard() ?? appendStop({});
    if (!targetStop) {
      return;
    }

    const selected = selectParkReference(targetStop, reference.toUpperCase());
    if (!selected) {
      editStatus?.replaceChildren(`Could not find ${reference} in the park list.`);
      return;
    }

    setupStopCards();
    targetStop.scrollIntoView({ behavior: "smooth", block: "center" });
    (targetStop.querySelector("[data-planned-date]") as HTMLSelectElement | null)?.focus();
    editStatus?.replaceChildren(`${reference.toUpperCase()} added to the activation plan. Choose the date, time, bands, and modes before saving.`);
  }

  function firstEmptyStopCard(): HTMLElement | null {
    return Array.from(document.querySelectorAll<HTMLElement>("[data-stop-card]"))
      .find((stop) => !stop.querySelector<HTMLInputElement>("[data-park-reference]")?.value) ?? null;
  }

  function selectParkReference(stop: HTMLElement, reference: string): boolean {
    if (!reference) {
      return false;
    }

    const parkInput = stop.querySelector<HTMLInputElement>("[data-park-input]");
    const parkReference = stop.querySelector<HTMLInputElement>("[data-park-reference]");
    const option = Array.from(stop.querySelectorAll<HTMLElement>("[data-park-option]"))
      .find((candidate) => candidate.dataset.reference === reference);

    if (!parkInput || !parkReference || !option) {
      return false;
    }

    parkInput.value = option.dataset.label ?? reference;
    parkReference.value = reference;
    return true;
  }

  function selectedParkReference(value: string, combobox: HTMLElement): string {
    const normalizedValue = value.toLowerCase();
    const selectedOption = Array.from(combobox.querySelectorAll<HTMLElement>("[data-park-option]"))
      .find((option) => (
        option.dataset.reference?.toLowerCase() === normalizedValue ||
        option.dataset.label?.toLowerCase() === normalizedValue
      ));

    return selectedOption?.dataset.reference ?? "";
  }

  function filterParkOptions(combobox: HTMLElement, value: string): void {
    const terms = value.toLowerCase().split(/\s+/).filter(Boolean);
    let visibleCount = 0;

    combobox.querySelectorAll<HTMLElement>("[data-park-option]").forEach((option) => {
      const search = option.dataset.search ?? "";
      const isVisible = terms.every((term) => search.includes(term));
      option.hidden = !isVisible;
      if (isVisible) {
        visibleCount += 1;
      }
    });

    const empty = combobox.querySelector<HTMLElement>("[data-park-empty]");
    if (empty) {
      empty.hidden = visibleCount > 0;
    }
  }

  function selectedValues(root: HTMLElement | null): string[] {
    return Array.from(root?.querySelectorAll<HTMLInputElement>("[data-multi-option]:checked") ?? [])
      .map((option) => option.value);
  }

  function setSelectedValues(root: HTMLElement | null, values: string[]): void {
    const selected = new Set(values);
    root?.querySelectorAll<HTMLInputElement>("[data-multi-option]").forEach((option) => {
      option.checked = selected.has(option.value);
    });
    if (root) {
      updateMultiSelectLabel(root);
    }
  }

  function setParkPopupOpen(combobox: HTMLElement, isOpen: boolean): void {
    combobox.querySelector<HTMLElement>("[data-park-results]")?.toggleAttribute("hidden", !isOpen);
    combobox.querySelector<HTMLInputElement>("[data-park-input]")?.setAttribute("aria-expanded", String(isOpen));
  }

  function setMultiSelectOpen(multiSelect: HTMLElement, isOpen: boolean): void {
    multiSelect.querySelector<HTMLElement>("[data-multi-menu]")?.toggleAttribute("hidden", !isOpen);
    multiSelect.querySelector<HTMLButtonElement>("[data-multi-toggle]")?.setAttribute("aria-expanded", String(isOpen));
  }

  function updateMultiSelectLabel(multiSelect: HTMLElement): void {
    const toggle = multiSelect.querySelector<HTMLButtonElement>("[data-multi-toggle]");
    const values = selectedValues(multiSelect);

    if (!toggle) {
      return;
    }

    toggle.textContent = values.length > 0 ? values.join(", ") : multiSelect.hasAttribute("data-bands") ? "Choose bands" : "Choose modes";
  }

  function resetTurnstile(): void {
    const turnstile = (
      globalThis as {
        turnstile?: {
          reset?: () => void;
        };
      }
    ).turnstile;

    turnstile?.reset?.();
  }

  function setEditStatus(message: string, kind?: "error" | "success"): void {
    editStatus?.replaceChildren(message);

    if (!editStatus || !(editStatus instanceof HTMLElement)) {
      return;
    }

    if (kind) {
      editStatus.dataset.status = kind;
    } else {
      delete editStatus.dataset.status;
    }
  }

  function showEditConfirmation(): void {
    if (editConfirmation?.showModal) {
      editConfirmation.showModal();
      editConfirmation.querySelector<HTMLAnchorElement>("[data-edit-confirmation-overview]")?.focus();
    }
  }

  function apiUrl(): string {
    return `/api/activate-ri-2026/edit/${encodeURIComponent(editToken())}/plans`;
  }

  function selectedPlanUrl(): string {
    return `${apiUrl()}/${encodeURIComponent(selectedPlanId)}`;
  }

  function editToken(): string {
    const pathParts = window.location.pathname.split("/").filter(Boolean);

    return pathParts[0] === "activate-ri-2026" && pathParts[1] === "edit"
      ? pathParts[2] ?? ""
      : "";
  }

  async function parseResponse(response: Response): Promise<{
    ok?: boolean;
    plans?: unknown;
    error?: string;
    errors?: string[];
  }> {
    const contentType = response.headers.get("content-type") ?? "";

    return contentType.includes("application/json") ? response.json() : {};
  }

  function setNamedValue(name: string, value: string): void {
    const field = editForm?.elements.namedItem(name);
    if (field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement) {
      field.value = value;
    }
  }

  function setValue(root: HTMLElement, selector: string, value: string): void {
    const field = root.querySelector(selector) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement | null;
    if (field) {
      field.value = value;
    }
  }

  function timeBlockValue(stop: StopDto): string {
    const startTime = stringValue(stop.start_time);
    const endTime = stringValue(stop.end_time);
    const value = `${startTime}-${endTime}`;

    return timeBlockToRange(value) ? value : "";
  }

  function arrayValue(value: unknown): string[] {
    return Array.isArray(value)
      ? value.filter((item): item is string => typeof item === "string")
      : [];
  }

  function stringValue(value: unknown): string {
    return typeof value === "string" ? value : "";
  }
</script>
