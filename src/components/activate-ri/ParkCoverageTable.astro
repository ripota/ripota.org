---
import parks from "../../../public/data/activate-ri-2026/parks.json";
import { deriveParkCoverage, isParkVolunteerActionable } from "../../lib/activate-ri/coverage";
import {
  formatActivatorModes,
  timelineOptions,
  uniqueSortedValues,
} from "../../lib/activate-ri/listing";
import {
  activationTimeZoneOptions,
  formatActivationDate,
  formatActivationTimeRange,
} from "../../lib/activate-ri/time";
import type { ParkCoverage, PublicParkSummary } from "../../lib/activate-ri/types";

const publicParks = parks as PublicParkSummary[];
const visibleCoverage = deriveParkCoverage(publicParks, []);
const countyOptions = uniqueSortedValues(
  publicParks.map((park) => (park.counties?.length ? park.counties : ["Unknown county"])),
);

const statusLabels: Record<string, string> = {
  uncovered: "Needs coverage",
  scheduled: "Scheduled",
  "multiple-scheduled": "Multiple scheduled",
  "cancelled-needs-replacement": "Needs replacement",
  completed: "Completed",
};

function formatStop(stop: ParkCoverage["nextStop"]) {
  if (!stop) {
    return "Needs coverage";
  }

  return `${formatActivationDate(stop)}, ${formatActivationTimeRange(stop)}`;
}

function formatList(items: string[]) {
  return items.length > 0 ? items.join(", ") : "TBD";
}

function dataList(items: string[]) {
  return items.join("|");
}

function volunteerHref(reference: string) {
  return `/activate-ri-2026/volunteer/?park=${encodeURIComponent(reference)}`;
}

function parkCounties(park: ParkCoverage) {
  const source = publicParks.find((candidate) => candidate.reference === park.reference);
  const counties = source?.counties ?? [];

  return counties.length > 0 ? counties : ["Unknown county"];
}
---

<form class="event-filters" data-event-filters aria-label="Park coverage filters">
  <label class="event-filter">
    Timezone
    <select class="event-filter__control" data-timezone>
      {
        activationTimeZoneOptions.map((option) => (
          <option value={option.value} selected={option.value === "eastern"}>
            {option.label}
          </option>
        ))
      }
    </select>
  </label>
  <label class="event-filter">
    Mode
    <select class="event-filter__control" data-filter="mode">
      <option value="all">Any mode</option>
    </select>
  </label>
  <label class="event-filter">
    Band
    <select class="event-filter__control" data-filter="band">
      <option value="all">Any band</option>
    </select>
  </label>
  <label class="event-filter">
    Timeline
    <select class="event-filter__control" data-filter="timeline">
      {timelineOptions.map((option) => <option value={option.value}>{option.label}</option>)}
    </select>
  </label>
  <label class="event-filter">
    County
    <select class="event-filter__control" data-filter="county">
      <option value="all">Any county</option>
      {countyOptions.map((county) => <option value={county}>{county}</option>)}
    </select>
  </label>
</form>

<div class="event-table-wrap">
  <table class="event-table" data-filtered-table data-live-coverage data-parks={JSON.stringify(publicParks)}>
    <thead>
      <tr>
        <th scope="col">Park</th>
        <th scope="col">Status</th>
        <th scope="col">Next activation</th>
        <th scope="col">Activator</th>
        <th scope="col">Bands / modes</th>
      </tr>
    </thead>
    <tbody>
      {
        visibleCoverage.map((park) => (
          <tr
            data-filter-row
            data-counties={dataList(parkCounties(park))}
            data-has-stops={park.stops.length > 0 ? "true" : "false"}
          >
            <th scope="row" data-label="Park">
              {park.name}
              <span>{park.reference}</span>
              <span>{formatList(parkCounties(park))}</span>
            </th>
            <td data-label="Status">
              {statusLabels[park.status] ?? park.status}
              {isParkVolunteerActionable(park.status) && (
                <a class="button event-table-action" href={volunteerHref(park.reference)}>
                  Volunteer
                </a>
              )}
            </td>
            <td data-label="Next activation">
              {park.stops.length > 0 ? (
                <div class="event-stop-list">
                  {park.stops.map((stop) => (
                    <div
                      class="event-stop-list__item"
                      data-filter-stop
                      data-bands={dataList(stop.bands)}
                      data-date={stop.plannedDate}
                      data-modes={dataList(stop.modes)}
                    >
                      {formatStop(stop)}
                      <span>{statusLabels[stop.status] ?? stop.status}</span>
                    </div>
                  ))}
                </div>
              ) : (
                "Needs coverage"
              )}
            </td>
            <td data-label="Activator">
              {park.stops.length > 0 ? (
                <div class="event-stop-list">
                  {park.stops.map((stop) => (
                    <div
                      class="event-stop-list__item"
                      data-filter-stop
                      data-bands={dataList(stop.bands)}
                      data-date={stop.plannedDate}
                      data-modes={dataList(stop.modes)}
                    >
                      {formatActivatorModes(stop)}
                    </div>
                  ))}
                </div>
              ) : (
                "TBD"
              )}
            </td>
            <td data-label="Bands / modes">
              {park.stops.length > 0 ? (
                <div class="event-stop-list">
                  {park.stops.map((stop) => (
                    <div
                      class="event-stop-list__item"
                      data-filter-stop
                      data-bands={dataList(stop.bands)}
                      data-date={stop.plannedDate}
                      data-modes={dataList(stop.modes)}
                    >
                      {formatList(stop.bands)} / {formatList(stop.modes)}
                    </div>
                  ))}
                </div>
              ) : (
                "TBD"
              )}
            </td>
          </tr>
        ))
      }
      <tr data-filter-empty hidden>
        <td colspan="5" data-label="Park coverage">No parks match these filters.</td>
      </tr>
    </tbody>
  </table>
</div>

<script>
  import { fetchPublicActivationStops } from "../../lib/activate-ri/public-stops-client";
  import {
    formatActivationDate,
    formatActivationTimeRange,
    timeZoneOptionForValue,
  } from "../../lib/activate-ri/time";

  const volunteerActionableStatuses = new Set(["uncovered", "cancelled-needs-replacement"]);

  document.querySelectorAll("[data-event-filters]").forEach(setupParkFilters);
  document.querySelectorAll<HTMLTableElement>("[data-live-coverage]").forEach(setupLiveCoverage);

  function setupParkFilters(root: Element): void {
    const filters = root as HTMLFormElement;
    const table = filters.nextElementSibling?.querySelector("[data-filtered-table]");
    const timezoneControl = filters.querySelector("[data-timezone]") as HTMLSelectElement | null;

    if (timezoneControl) {
      timezoneControl.value = timeZoneOptionForValue(new URLSearchParams(window.location.search).get("timezone")).value;
    }

    const applyFilters = () => {
      const rows = Array.from(table?.querySelectorAll<HTMLElement>("[data-filter-row]") ?? []);
      const empty = table?.querySelector<HTMLElement>("[data-filter-empty]");
      const controls = Array.from(
        filters.querySelectorAll("[data-filter]"),
      ) as unknown as HTMLSelectElement[];
      const values = Object.fromEntries(
        controls.map((control) => [control.dataset.filter ?? "", control.value]),
      );
      const hasStopFilters =
        active(values.mode) || active(values.band) || active(values.timeline);
      let visibleCount = 0;

      for (const row of rows) {
        const countyMatches = matchesList(row.dataset.counties, values.county);
        const stops = Array.from(row.querySelectorAll<HTMLElement>("[data-filter-stop]"));
        const matchingStops = stops.filter(
          (stop) =>
            matchesList(stop.dataset.modes, values.mode) &&
            matchesList(stop.dataset.bands, values.band) &&
            matchesTimeline(stop.dataset.date, values.timeline),
        );

        for (const stop of stops) {
          stop.hidden = hasStopFilters && !matchingStops.includes(stop);
        }

        const isVisible = countyMatches && (!hasStopFilters || matchingStops.length > 0);
        row.hidden = !isVisible;
        visibleCount += isVisible ? 1 : 0;
      }

      if (empty) {
        empty.hidden = visibleCount > 0 || rows.length === 0;
      }
    };

    filters.onchange = (event) => {
      if (timezoneControl && event.target === timezoneControl) {
        updateTimezoneUrl(timezoneControl.value);
      }
      applyTimezone(table, timezoneControl?.value ?? "eastern");
      applyFilters();
    };
    applyTimezone(table, timezoneControl?.value ?? "eastern");
    applyFilters();
  }

  async function setupLiveCoverage(table: HTMLTableElement): Promise<void> {
    const body = table.querySelector("tbody");
    if (!body) {
      return;
    }

    let parks: PublicPark[] = [];
    try {
      parks = JSON.parse(table.dataset.parks ?? "[]");
    } catch {
      parks = [];
    }

    try {
      const stops = await fetchPublicActivationStops();
      const visibleStops = stops.filter((stop) => !stop.id.startsWith("sample-"));
      const filters = document.querySelector("[data-event-filters]") as HTMLFormElement | null;
      renderLiveCoverage(body, parks, visibleStops);
      if (filters) {
        updateSelectOptions(filters, "mode", uniqueSortedValues(visibleStops.map((stop) => stop.modes)));
        updateSelectOptions(filters, "band", uniqueSortedValues(visibleStops.map((stop) => stop.bands)));
        setupParkFilters(filters);
      }
    } catch {
      renderCoverageUnavailable(body);
      const filters = document.querySelector("[data-event-filters]") as HTMLFormElement | null;
      if (filters) {
        setupParkFilters(filters);
      }
    }
  }

  function updateSelectOptions(
    filters: HTMLFormElement,
    filterName: "mode" | "band",
    values: string[],
  ): void {
    const control = filters.querySelector(`[data-filter="${filterName}"]`) as HTMLSelectElement | null;
    if (!control) {
      return;
    }

    const current = control.value;
    control.replaceChildren(new Option(filterName === "mode" ? "Any mode" : "Any band", "all"));
    for (const value of values) {
      control.appendChild(new Option(value, value));
    }
    control.value = values.includes(current) ? current : "all";
  }

  function uniqueSortedValues(values: string[][]): string[] {
    return [...new Set(values.flat().filter(Boolean))].sort((left, right) =>
      left.localeCompare(right),
    );
  }

  type PublicPark = {
    reference: string;
    name: string;
    counties?: string[];
  };

  type PublicStop = {
    id: string;
    parkReference: string;
    plannedDate: string;
    startTime: string;
    endTime: string;
    activatorCallsign: string;
    bands: string[];
    modes: string[];
    status: string;
  };

  type CoverageRow = PublicPark & {
    status: string;
    stops: PublicStop[];
  };

  function renderLiveCoverage(
    body: HTMLTableSectionElement,
    parks: PublicPark[],
    stops: PublicStop[],
  ): void {
    body.replaceChildren(
      ...deriveCoverage(parks, stops).map(createCoverageRow),
      createCoverageEmptyRow(),
    );
  }

  function renderCoverageUnavailable(body: HTMLTableSectionElement): void {
    const row = document.createElement("tr");
    const cell = document.createElement("td");
    cell.colSpan = 5;
    cell.dataset.label = "Park coverage";
    cell.textContent = "Live coverage is unavailable. Try refreshing this page.";
    row.appendChild(cell);
    body.replaceChildren(row);
  }

  function deriveCoverage(parks: PublicPark[], stops: PublicStop[]): CoverageRow[] {
    return parks.map((park) => {
      const parkStops = stops
        .filter((stop) => stop.parkReference === park.reference)
        .sort((left, right) =>
          `${left.plannedDate}T${left.startTime}`.localeCompare(`${right.plannedDate}T${right.startTime}`),
        );
      const scheduledCount = parkStops.filter((stop) => stop.status === "scheduled" || stop.status === "delayed").length;
      const cancelledCount = parkStops.filter((stop) => stop.status === "cancelled").length;
      const completedCount = parkStops.filter((stop) => stop.status === "completed").length;

      return {
        ...park,
        stops: parkStops,
        status: coverageStatus(scheduledCount, cancelledCount, completedCount),
      };
    });
  }

  function createCoverageRow(park: CoverageRow): HTMLTableRowElement {
    const row = document.createElement("tr");
    row.dataset.filterRow = "";
    row.dataset.counties = countyList(park).join("|");
    row.dataset.hasStops = park.stops.length > 0 ? "true" : "false";

    const heading = document.createElement("th");
    heading.scope = "row";
    heading.dataset.label = "Park";
    heading.append(park.name);
    for (const value of [park.reference, countyList(park).join(", ")]) {
      const span = document.createElement("span");
      span.textContent = value;
      heading.appendChild(span);
    }
    row.appendChild(heading);

    appendStatusCell(row, park);
    appendStopListCell(row, "Next activation", park.stops, formatStopDetails);
    appendStopListCell(row, "Activator", park.stops, (stop) => [
      `${stop.activatorCallsign}${stop.modes.length > 0 ? ` (${stop.modes.join(", ")})` : ""}`,
    ]);
    appendStopListCell(row, "Bands / modes", park.stops, (stop) => [
      `${stop.bands.length ? stop.bands.join(", ") : "TBD"} / ${stop.modes.length ? stop.modes.join(", ") : "TBD"}`,
    ]);

    return row;
  }

  function appendStatusCell(row: HTMLTableRowElement, park: CoverageRow): void {
    const cell = document.createElement("td");
    cell.dataset.label = "Status";
    cell.append(coverageStatusLabel(park.status));

    if (isParkVolunteerActionable(park.status)) {
      const link = document.createElement("a");
      link.className = "button event-table-action";
      link.href = volunteerHref(park.reference);
      link.textContent = "Volunteer";
      cell.appendChild(link);
    }

    row.appendChild(cell);
  }

  function appendStopListCell(
    row: HTMLTableRowElement,
    label: string,
    stops: PublicStop[],
    format: (stop: PublicStop) => string[],
  ): void {
    const cell = document.createElement("td");
    cell.dataset.label = label;
    if (stops.length === 0) {
      cell.textContent = row.children.length === 2 ? "Needs coverage" : "TBD";
      row.appendChild(cell);
      return;
    }

    const list = document.createElement("div");
    list.className = "event-stop-list";
    for (const stop of stops) {
      const item = document.createElement("div");
      item.className = "event-stop-list__item";
      item.dataset.filterStop = "";
      item.dataset.bands = stop.bands.join("|");
      item.dataset.date = stop.plannedDate;
      item.dataset.startTime = stop.startTime;
      item.dataset.endTime = stop.endTime;
      item.dataset.modes = stop.modes.join("|");
      const [primary, secondary] = format(stop);
      if (label === "Next activation") {
        item.dataset.coverageTime = "";
      }
      item.append(primary);
      if (secondary) {
        const span = document.createElement("span");
        span.textContent = secondary;
        item.appendChild(span);
      }
      list.appendChild(item);
    }
    cell.appendChild(list);
    row.appendChild(cell);
  }

  function formatStopDetails(stop: PublicStop): string[] {
    return [
      `${formatActivationDate(stop)}, ${formatActivationTimeRange(stop)}`,
      stopStatusLabel(stop.status),
    ];
  }

  function applyTimezone(table: Element | null | undefined, value: string): void {
    const option = timeZoneOptionForValue(value);
    table?.querySelectorAll<HTMLElement>("[data-coverage-time]").forEach((item) => {
      const plannedDate = item.dataset.date;
      const startTime = item.dataset.startTime;
      const endTime = item.dataset.endTime;
      if (!plannedDate || !startTime || !endTime) {
        return;
      }

      const primary = item.firstChild;
      const text = `${formatActivationDate({ plannedDate, startTime }, option)}, ${formatActivationTimeRange({ plannedDate, startTime, endTime }, option)}`;
      if (primary instanceof Text) {
        primary.data = text;
      } else {
        item.prepend(text);
      }
    });
  }

  function updateTimezoneUrl(value: string): void {
    const url = new URL(window.location.href);
    url.searchParams.set("timezone", timeZoneOptionForValue(value).value);
    window.history.replaceState({}, "", url);
  }

  function createCoverageEmptyRow(): HTMLTableRowElement {
    const row = document.createElement("tr");
    row.dataset.filterEmpty = "";
    row.hidden = true;
    const cell = document.createElement("td");
    cell.colSpan = 5;
    cell.dataset.label = "Park coverage";
    cell.textContent = "No parks match these filters.";
    row.appendChild(cell);
    return row;
  }

  function coverageStatus(scheduledCount: number, cancelledCount: number, completedCount: number): string {
    if (scheduledCount > 1) {
      return "multiple-scheduled";
    }
    if (scheduledCount === 1) {
      return "scheduled";
    }
    if (completedCount > 0) {
      return "completed";
    }
    if (cancelledCount > 0) {
      return "cancelled-needs-replacement";
    }
    return "uncovered";
  }

  function countyList(park: PublicPark): string[] {
    return park.counties?.length ? park.counties : ["Unknown county"];
  }

  function coverageStatusLabel(status: string): string {
    return {
      uncovered: "Needs coverage",
      scheduled: "Scheduled",
      "multiple-scheduled": "Multiple scheduled",
      "cancelled-needs-replacement": "Needs replacement",
      completed: "Completed",
    }[status] ?? status;
  }

  function isParkVolunteerActionable(status: string): boolean {
    return volunteerActionableStatuses.has(status);
  }

  function volunteerHref(reference: string): string {
    return `/activate-ri-2026/volunteer/?park=${encodeURIComponent(reference)}`;
  }

  function stopStatusLabel(status: string): string {
    return {
      "pending-review": "Pending review",
      scheduled: "Scheduled",
      delayed: "Delayed",
      cancelled: "Cancelled",
      completed: "Completed",
    }[status] ?? status;
  }

  function active(value: string | undefined): boolean {
    return Boolean(value && value !== "all");
  }

  function matchesList(value: string | undefined, filter: string | undefined): boolean {
    return !filter || filter === "all" || String(value ?? "").split("|").includes(filter);
  }

  function matchesTimeline(date: string | undefined, filter: string | undefined): boolean {
    if (!filter || filter === "all") {
      return true;
    }

    if (filter === "soft-start") {
      return date === "2026-09-10";
    }

    if (filter === "main") {
      return date === "2026-09-11" || date === "2026-09-12" || date === "2026-09-13";
    }

    return date === filter;
  }
</script>
