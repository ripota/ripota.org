---
import parks from "../../../public/data/activate-ri-2026/parks.json";
import ReferenceMap from "../ReferenceMap.astro";
import { activateRi2026Event } from "../../data/activate-ri-2026/event";
import type { PublicParkSummary } from "../../lib/activate-ri/types";

const ctas = activateRi2026Event.phaseCtas[activateRi2026Event.phase];
const dateRangeLabel = formatDateRange(
  activateRi2026Event.mainStartDate,
  activateRi2026Event.mainEndDate,
);
const softStartLabel = formatMonthDay(activateRi2026Event.softStartDate);
const publicParks = parks as PublicParkSummary[];

function parseEventDate(date: string) {
  const [year, month, day] = date.split("-").map(Number);
  return { year, month, day, value: new Date(Date.UTC(year, month - 1, day)) };
}

function formatMonthDay(date: string) {
  return new Intl.DateTimeFormat("en-US", {
    month: "long",
    day: "numeric",
    timeZone: "UTC",
  }).format(parseEventDate(date).value);
}

function formatDateRange(startDate: string, endDate: string) {
  const start = parseEventDate(startDate);
  const end = parseEventDate(endDate);
  const startMonth = formatMonthDay(startDate).replace(` ${start.day}`, "");
  const endMonthDay = formatMonthDay(endDate);

  if (start.year === end.year && start.month === end.month) {
    return `${startMonth} ${start.day}-${end.day}, ${start.year}`;
  }

  if (start.year === end.year) {
    return `${formatMonthDay(startDate)}-${endMonthDay}, ${start.year}`;
  }

  return `${formatMonthDay(startDate)}, ${start.year}-${endMonthDay}, ${end.year}`;
}
---

<section class="event-hero" aria-labelledby="event-title">
  <div class="container event-hero__inner">
    <div class="event-hero__content">
      <p class="eyebrow">{dateRangeLabel}</p>
      <h1 id="event-title">Activate All RI</h1>
      <p class="event-hero__copy">
        Help the Rhode Island POTA community cover all {activateRi2026Event.goalParkCount}
        Rhode Island references during one coordinated weekend. A soft start is
        planned for {softStartLabel}.
      </p>
      <dl
        class="event-hero__stats"
        aria-label="Activate All RI coverage progress"
        data-live-hero-coverage
        data-parks={JSON.stringify(publicParks)}
      >
        <div>
          <dt>Parks scheduled</dt>
          <dd data-hero-scheduled>Loading...</dd>
        </div>
        <div>
          <dt>Coverage gaps</dt>
          <dd data-hero-gaps>Loading...</dd>
        </div>
      </dl>
      <div class="button-row" aria-label="Event actions">
        <a class="button" data-variant="primary" href={ctas.primary.href}>
          {ctas.primary.label}
        </a>
        <a class="button" data-variant="light" href={ctas.secondary.href}>
          {ctas.secondary.label}
        </a>
      </div>
    </div>
    <div class="event-hero__map">
      <ReferenceMap
        id="activate-ri-hero-coverage-map"
        variant="coverage"
        title="Map of Activate All RI 2026 coverage"
        caption="Coverage means a planned activation window for community coordination. Official Parks on the Air resources remain authoritative for rules, spots, logs, awards, and activation validity."
        phaseFocus="volunteer"
        legendPlacement="overlay"
        legendTitle="Volunteer coverage"
      />
    </div>
  </div>
</section>

<script>
  import { summarizeParkCoverage } from "../../lib/activate-ri/coverage";
  import { fetchPublicActivationStops } from "../../lib/activate-ri/public-stops-client";
  import type { PublicParkSummary } from "../../lib/activate-ri/types";

  function setHeroCoverageText(
    summary: Element,
    scheduled: string,
    gaps: string,
  ): void {
    const scheduledValue = summary.querySelector("[data-hero-scheduled]");
    const gapsValue = summary.querySelector("[data-hero-gaps]");

    if (scheduledValue) {
      scheduledValue.textContent = scheduled;
    }

    if (gapsValue) {
      gapsValue.textContent = gaps;
    }
  }

  async function setupLiveHeroCoverage(summary: HTMLElement): Promise<void> {
    try {
      const parks = JSON.parse(summary.dataset.parks ?? "[]") as PublicParkSummary[];
      const stops = await fetchPublicActivationStops();

      const coverageSummary = summarizeParkCoverage(parks, stops);
      setHeroCoverageText(
        summary,
        `${coverageSummary.scheduled} / ${coverageSummary.total}`,
        `${coverageSummary.gaps}`,
      );
    } catch {
      setHeroCoverageText(summary, "Unavailable", "Unavailable");
    }
  }

  document
    .querySelectorAll<HTMLElement>("[data-live-hero-coverage]")
    .forEach((summary) => {
      void setupLiveHeroCoverage(summary);
    });
</script>
