{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "ripota-org",
  "main": "src/worker/index.ts",
  "compatibility_date": "2026-06-14",
  "build": {
    "command": "npm run build"
  },
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*", "/activate-ri-2026/edit/*"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "ripota-org",
      "database_id": "5fa75a4d-9387-437d-9f81-ebb06b645747"
    }
  ],
  "vars": {
    "ACTIVATE_RI_EVENT_ID": "activate-ri-2026",
    "PUBLIC_TURNSTILE_SITE_KEY": "1x00000000000000000000AA",
    "TURNSTILE_REQUIRED": "false"
  },
  "env": {
    "production": {
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "ripota-org",
          "database_id": "5fa75a4d-9387-437d-9f81-ebb06b645747"
        }
      ],
      "vars": {
        "ACTIVATE_RI_EVENT_ID": "activate-ri-2026",
        "PUBLIC_TURNSTILE_SITE_KEY": "REPLACE_WITH_PRODUCTION_TURNSTILE_SITE_KEY",
        "TURNSTILE_REQUIRED": "true"
      }
    }
  },
  "observability": {
    "enabled": true
  }
}
